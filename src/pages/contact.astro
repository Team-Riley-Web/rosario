---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { Image } from 'astro:assets';
import founderImg from '../assets/images/brittani.jpg';
import groupImg from '../assets/images/group2.jpg';
---

<Layout
  title="Contact CFC Skincare — Skin Consultations & Support"
  description="Contact CFC Skincare for product guidance, skin consultations, order support, and local pickup questions."
>
  <Nav />

  <main>
    <section class="bg-ink pt-[160px] pb-[90px] relative overflow-hidden">
      <div class="max-w-[1440px] mx-auto px-6 sm:px-10 relative z-10">
        <div class="grid grid-cols-1 lg:grid-cols-[7fr_5fr] gap-14 lg:gap-24 items-end">
          <div class="reveal max-w-[760px]">
            <div class="flex items-center gap-4 mb-8">
              <div class="h-px bg-gold w-6"></div>
              <span class="font-mono text-[10px] tracking-[0.2em] uppercase text-gold">Contact CFC</span>
            </div>
            <h1
              class="font-display font-light text-white leading-[1.0] tracking-[-0.02em] mb-8"
              style="font-size: clamp(52px, 6vw, 92px);"
            >
              Start with a real conversation.
            </h1>
            <p class="font-sans font-light text-[16px] leading-[1.75] max-w-[560px]" style="color: rgba(255,255,255,0.58);">
              Tell us what your skin is doing, what you have already tried, and where you want help. Product guidance, routine support, order questions, and local pickup details all start here.
            </p>
          </div>

          <div class="reveal-right border border-[rgba(255,255,255,0.08)] bg-[rgba(255,255,255,0.03)] p-7 sm:p-8">
            <div class="grid gap-5 items-start" style="grid-template-columns: 72px 1fr;">
              <Image
                src={founderImg}
                alt="Brittany, NP-C — Founder of CFC Skincare"
                class="object-cover object-top w-[72px] h-[72px]"
                widths={[144]}
                sizes="72px"
              />
              <div>
                <p class="font-display text-[20px] font-normal text-white mb-2">Founder-led guidance</p>
                <p class="font-sans font-light text-[13px] leading-relaxed" style="color: rgba(255,255,255,0.55);">
                  Messages are reviewed by the CFC team for practical, product-specific next steps.
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
      <div class="absolute bottom-0 inset-x-0 h-px" style="background: rgba(255,255,255,0.06);"></div>
    </section>

    <section class="bg-parchment py-[110px]">
      <div class="max-w-[1440px] mx-auto px-6 sm:px-10">
        <div class="grid grid-cols-1 lg:grid-cols-[4fr_8fr] gap-14 lg:gap-24 items-start">
          <aside class="reveal-left lg:sticky lg:top-28">
            <div class="flex items-center gap-4 mb-7">
              <div class="h-px bg-gold w-6"></div>
              <span class="font-mono text-[10px] tracking-[0.2em] uppercase text-gold">How We Can Help</span>
            </div>

            <h2 class="font-display font-light text-ink leading-[1.08] tracking-[-0.01em] mb-7" style="font-size: clamp(34px, 3.4vw, 54px);">
              Product advice without the guessing.
            </h2>

            <p class="font-sans font-light text-[14px] text-ink-soft leading-[1.8] mb-9 max-w-[420px]">
              Use the form for skin consultations, product matching, order support, local pickup questions, wholesale inquiries, or press requests.
            </p>

            <div class="border border-rule bg-white">
              {[
                ['Response window', 'Within 1 business day'],
                ['Consultation cost', 'Free product guidance'],
                ['Privacy', 'Skin details stay confidential'],
                ['Order help', 'Include your order number'],
              ].map(([label, value], i) => (
                <div class={`p-5 ${i < 3 ? 'border-b border-rule' : ''}`}>
                  <p class="font-mono text-[9px] tracking-[0.18em] uppercase text-gold mb-1.5">{label}</p>
                  <p class="font-sans text-[14px] text-ink">{value}</p>
                </div>
              ))}
            </div>
          </aside>

          <div class="reveal-right">
            <form
              name="contact"
              method="POST"
              data-netlify="true"
              netlify-honeypot="bot-field"
              x-data="{ submitted: false, topic: '' }"
              @submit.prevent="
                fetch('/', {
                  method: 'POST',
                  headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                  body: new URLSearchParams(new FormData($el)).toString()
                }).then(() => { submitted = true; });
              "
              class="bg-white border border-rule p-6 sm:p-10 lg:p-14"
            >
              <input type="hidden" name="form-name" value="contact" />
              <p class="hidden">
                <label>Do not fill this out: <input name="bot-field" /></label>
              </p>

              <div x-show="submitted" class="text-center py-10">
                <div class="w-16 h-16 bg-parchment flex items-center justify-center mx-auto mb-5">
                  <svg class="w-8 h-8 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 13l4 4L19 7" />
                  </svg>
                </div>
                <h3 class="font-display text-[28px] font-normal text-ink mb-2">Message received.</h3>
                <p class="font-sans font-light text-[14px] text-ink-soft">We will respond within 1 business day.</p>
              </div>

              <div x-show="!submitted" class="space-y-6">
                <div>
                  <p class="font-mono text-[10px] tracking-[0.2em] uppercase text-gold mb-3">Contact Form</p>
                  <h2 class="font-display font-light text-ink leading-tight tracking-[-0.01em]" style="font-size: clamp(30px, 3vw, 44px);">
                    Tell us what you need.
                  </h2>
                </div>

                <div class="grid sm:grid-cols-2 gap-5">
                  <div>
                    <label for="first_name" class="block font-mono text-[9px] tracking-[0.2em] uppercase text-ink-soft mb-2">First Name</label>
                    <input
                      id="first_name"
                      type="text"
                      name="first_name"
                      required
                      autocomplete="given-name"
                      class="w-full font-sans text-[14px] text-ink bg-parchment border border-rule transition-colors duration-200 focus:outline-none focus:border-gold"
                      style="padding: 14px 16px;"
                    />
                  </div>
                  <div>
                    <label for="last_name" class="block font-mono text-[9px] tracking-[0.2em] uppercase text-ink-soft mb-2">Last Name</label>
                    <input
                      id="last_name"
                      type="text"
                      name="last_name"
                      required
                      autocomplete="family-name"
                      class="w-full font-sans text-[14px] text-ink bg-parchment border border-rule transition-colors duration-200 focus:outline-none focus:border-gold"
                      style="padding: 14px 16px;"
                    />
                  </div>
                </div>

                <div class="grid sm:grid-cols-2 gap-5">
                  <div>
                    <label for="email" class="block font-mono text-[9px] tracking-[0.2em] uppercase text-ink-soft mb-2">Email</label>
                    <input
                      id="email"
                      type="email"
                      name="email"
                      required
                      autocomplete="email"
                      class="w-full font-sans text-[14px] text-ink bg-parchment border border-rule transition-colors duration-200 focus:outline-none focus:border-gold"
                      style="padding: 14px 16px;"
                    />
                  </div>
                  <div>
                    <label for="phone" class="block font-mono text-[9px] tracking-[0.2em] uppercase text-ink-soft mb-2">Phone <span class="normal-case tracking-normal text-ink-soft">(optional)</span></label>
                    <input
                      id="phone"
                      type="tel"
                      name="phone"
                      autocomplete="tel"
                      class="w-full font-sans text-[14px] text-ink bg-parchment border border-rule transition-colors duration-200 focus:outline-none focus:border-gold"
                      style="padding: 14px 16px;"
                    />
                  </div>
                </div>

                <div>
                  <label for="topic" class="block font-mono text-[9px] tracking-[0.2em] uppercase text-ink-soft mb-2">Reason For Contact</label>
                  <select
                    id="topic"
                    name="topic"
                    required
                    x-model="topic"
                    class="w-full font-sans text-[14px] text-ink bg-parchment border border-rule transition-colors duration-200 focus:outline-none focus:border-gold appearance-none"
                    style="padding: 14px 16px;"
                  >
                    <option value="">Select a topic...</option>
                    <option>Skin Consultation</option>
                    <option>Product Recommendation</option>
                    <option>Order Support</option>
                    <option>Local Pickup</option>
                    <option>Wholesale Inquiry</option>
                    <option>Press / Partnership</option>
                    <option>Other</option>
                  </select>
                </div>

                <div x-show="topic === 'Skin Consultation' || topic === 'Product Recommendation'" class="grid sm:grid-cols-2 gap-5">
                  <div>
                    <label for="skin_concern" class="block font-mono text-[9px] tracking-[0.2em] uppercase text-ink-soft mb-2">Primary Skin Concern</label>
                    <select
                      id="skin_concern"
                      name="skin_concern"
                      class="w-full font-sans text-[14px] text-ink bg-parchment border border-rule transition-colors duration-200 focus:outline-none focus:border-gold appearance-none"
                      style="padding: 14px 16px;"
                    >
                      <option value="">Select a concern...</option>
                      <option>Pigmentation / Dark Spots</option>
                      <option>Fine Lines & Wrinkles</option>
                      <option>Dryness & Dehydration</option>
                      <option>Rosacea / Redness</option>
                      <option>Uneven Skin Tone</option>
                      <option>Sagging / Loss of Firmness</option>
                      <option>General Anti-Aging</option>
                      <option>Not Sure</option>
                    </select>
                  </div>
                  <div>
                    <label for="current_routine" class="block font-mono text-[9px] tracking-[0.2em] uppercase text-ink-soft mb-2">Current Routine</label>
                    <input
                      id="current_routine"
                      type="text"
                      name="current_routine"
                      class="w-full font-sans text-[14px] text-ink bg-parchment border border-rule transition-colors duration-200 focus:outline-none focus:border-gold"
                      style="padding: 14px 16px;"
                      placeholder="Cleanser, serum, SPF..."
                    />
                  </div>
                </div>

                <div x-show="topic === 'Order Support'">
                  <label for="order_number" class="block font-mono text-[9px] tracking-[0.2em] uppercase text-ink-soft mb-2">Order Number</label>
                  <input
                    id="order_number"
                    type="text"
                    name="order_number"
                    class="w-full font-sans text-[14px] text-ink bg-parchment border border-rule transition-colors duration-200 focus:outline-none focus:border-gold"
                    style="padding: 14px 16px;"
                    placeholder="#1001"
                  />
                </div>

                <div>
                  <label for="message" class="block font-mono text-[9px] tracking-[0.2em] uppercase text-ink-soft mb-2">Message</label>
                  <textarea
                    id="message"
                    name="message"
                    rows="6"
                    required
                    class="w-full font-sans text-[14px] text-ink bg-parchment border border-rule transition-colors duration-200 focus:outline-none focus:border-gold resize-none"
                    style="padding: 14px 16px;"
                    placeholder="Share the details that will help us respond well."
                  ></textarea>
                </div>

                <button
                  type="submit"
                  class="w-full bg-ink text-white font-mono text-[11px] tracking-[0.2em] uppercase transition-colors duration-200 hover:bg-gold-deep"
                  style="padding: 18px;"
                >
                  Send Message
                </button>
              </div>
            </form>
          </div>
        </div>
      </div>
    </section>

    <section class="bg-white py-[110px]">
      <div class="max-w-[1440px] mx-auto px-6 sm:px-10">
        <div class="grid grid-cols-1 lg:grid-cols-[5fr_7fr] gap-14 lg:gap-24 items-center">
          <div class="reveal-left overflow-hidden aspect-[4/3]">
            <Image
              src={groupImg}
              alt="CFC Skincare products and community"
              class="w-full h-full object-cover"
              widths={[640, 960, 1280]}
              sizes="(max-width: 1024px) 100vw, 42vw"
            />
          </div>

          <div class="reveal-right">
            <div class="flex items-center gap-4 mb-7">
              <div class="h-px bg-gold w-6"></div>
              <span class="font-mono text-[10px] tracking-[0.2em] uppercase text-gold">Before You Send</span>
            </div>
            <h2 class="font-display font-light text-ink leading-[1.08] tracking-[-0.01em] mb-8" style="font-size: clamp(34px, 3.4vw, 52px);">
              A few details help us guide you faster.
            </h2>

            <div class="border-t border-rule">
              {[
                ['Skin guidance', 'Tell us your skin type, main concern, current routine, and anything your skin reacts to.'],
                ['Order support', 'Include your order number and the email used at checkout.'],
                ['Local pickup', 'Send the product names you need and your preferred pickup window.'],
                ['Partnerships', 'Share your business, location, and what kind of collaboration you have in mind.'],
              ].map(([title, copy]) => (
                <div class="grid sm:grid-cols-[180px_1fr] gap-3 sm:gap-8 py-6 border-b border-rule">
                  <p class="font-display text-[20px] font-normal text-ink">{title}</p>
                  <p class="font-sans font-light text-[14px] leading-[1.75] text-ink-soft">{copy}</p>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
