---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import { Image } from 'astro:assets';
import founderImg from '../assets/images/brittani.jpg';
import groupImg from '../assets/images/group.jpg';
import familyImg from '../assets/images/family.jpg';
import brit1Img from '../assets/images/brit1.jpg';
import brit2Img from '../assets/images/brit2.jpg';
import brit3Img from '../assets/images/brit3.jpg';
import brit4Img from '../assets/images/brit4.jpg';
---

<Layout
  title="About CFC Skincare — Built by a Nurse Practitioner"
  description="CFC Skincare is a medical-grade, plant-based system created by Brittany, NP-C — built for women who are done guessing."
>
  <Nav />

  <main>

    <!-- Page hero -->
    <section class="bg-ink pt-[160px] pb-[100px] relative overflow-hidden">
      <div class="absolute inset-0 hidden lg:block">
        <Image
          src={brit3Img}
          alt="Brittany, NP-C in her clinical office"
          class="absolute inset-y-0 right-0 w-[58%] h-full object-cover object-center"
          widths={[900, 1300, 1800, 2400]}
          sizes="58vw"
          loading="eager"
        />
        <div class="absolute inset-0" style="background: linear-gradient(90deg, oklch(13% 0.010 255) 0%, oklch(13% 0.010 255) 42%, rgba(18,21,25,0.72) 66%, rgba(18,21,25,0.28) 100%);"></div>
      </div>
      <div class="max-w-[1440px] mx-auto px-10 relative z-10">
        <div class="reveal max-w-[680px]">
          <div class="flex items-center gap-4 mb-8">
            <div class="h-px bg-gold w-6"></div>
            <span class="font-mono text-[10px] tracking-[0.2em] uppercase text-gold">About CFC</span>
          </div>
          <h1
            class="font-display font-light text-white leading-[1.0] tracking-[-0.02em] mb-8"
            style="font-size: clamp(52px, 5.5vw, 84px);"
          >
            Built by someone who actually<br/>
            <em style="font-style: italic;">understands your skin.</em>
          </h1>
          <p class="font-sans font-light text-[16px] leading-[1.75] max-w-[520px]" style="color: rgba(255,255,255,0.55);">
            CFC Skincare is the bridge between clinical efficacy and clean beauty — a medical-grade, plant-based system created by a nurse practitioner, for women who are done guessing.
          </p>
        </div>
      </div>
      <!-- Decorative rule -->
      <div class="absolute bottom-0 inset-x-0 h-px" style="background: rgba(255,255,255,0.06);"></div>
    </section>

    <!-- Founder image story -->
    <section class="bg-white py-[70px]">
      <div class="max-w-[1440px] mx-auto px-10">
        <div class="grid grid-cols-1 md:grid-cols-[7fr_5fr] gap-px bg-rule border border-rule">
          <div class="reveal-left bg-white overflow-hidden aspect-[16/9] md:aspect-[21/10]">
            <Image
              src={brit1Img}
              alt="Brittany, NP-C standing in front of her clinical credentials"
              class="w-full h-full object-cover object-center"
              widths={[720, 1080, 1440, 2000]}
              sizes="(max-width: 768px) 100vw, 58vw"
            />
          </div>
          <div class="reveal-right bg-parchment p-8 sm:p-10 lg:p-12 flex flex-col justify-center">
            <p class="font-mono text-[9px] tracking-[0.2em] uppercase text-gold mb-4">Clinical Perspective</p>
            <h2 class="font-display font-light text-ink leading-[1.08] tracking-[-0.01em] mb-5" style="font-size: clamp(30px, 3vw, 44px);">
              Built from medical training, lived experience, and years of patient conversations.
            </h2>
            <p class="font-sans font-light text-[14px] leading-[1.8] text-ink-soft">
              CFC reflects Brittany's clinical standards and her belief that skincare should be understandable, effective, and realistic for women at every stage.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Mission -->
    <section class="bg-parchment py-[120px]">
      <div class="max-w-[1440px] mx-auto px-10">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-32 items-start">

          <div class="reveal-left">
            <div class="flex items-center gap-4 mb-7">
              <div class="h-px bg-gold w-6"></div>
              <span class="font-mono text-[10px] tracking-[0.2em] uppercase text-gold">Our Mission</span>
            </div>
            <h2 class="font-display font-light text-ink leading-[1.08] tracking-[-0.01em]" style="font-size: clamp(32px, 3.2vw, 48px);">
              To empower every woman to embrace her unique skin journey — with the right knowledge and the right products.
            </h2>
          </div>

          <div class="reveal-right">
            <p class="font-sans font-light text-[15px] leading-[1.8] text-ink-soft mb-6">
              At CFC Skincare, our mission is to empower adults, teens, and tweens to embrace their unique skin journeys by educating them on the importance of healthy skincare habits and the selection of effective products.
            </p>
            <p class="font-sans font-light text-[15px] leading-[1.8] text-ink-soft mb-10">
              We believe that understanding the right active ingredients is essential for nurturing youthful skin. By providing access to medical-grade skincare solutions, we ensure our community receives the purest, most effective ingredients for their skin — and the confidence that comes with it.
            </p>

            <!-- Guarantees -->
            <div class="grid grid-cols-1 sm:grid-cols-3 gap-px bg-rule border border-rule">
              {[
                ['Easy Shipping', 'Or local pick up'],
                ['Your Satisfaction', 'Our top priority'],
                ['Medical-Grade', 'Skin care always'],
              ].map(([title, desc]) => (
                <div class="bg-white p-6">
                  <div class="h-px bg-gold mb-4 w-5"></div>
                  <p class="font-display text-[17px] font-normal text-ink mb-1">{title}</p>
                  <p class="font-mono text-ink-soft uppercase text-[9px] tracking-[0.14em]">{desc}</p>
                </div>
              ))}
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- Founder -->
    <section class="bg-white py-[120px]">
      <div class="max-w-[1440px] mx-auto px-10">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24 items-center">

          <!-- Photo -->
          <div class="reveal-left relative overflow-hidden aspect-[3/4]">
            <Image
              src={brit2Img}
              alt="Brittany, NP-C — Founder of CFC Skincare"
              class="w-full h-full object-cover object-top"
              widths={[600, 900, 1200]}
              sizes="(max-width: 1024px) 100vw, 50vw"
            />
            <!-- Inset credential badge -->
            <div class="absolute bottom-6 left-6 bg-ink px-5 py-4 max-w-[220px]">
              <p class="font-display italic font-light text-white mb-2 text-[14px] leading-[1.4]">
                "I built the system I wished existed when I was the patient."
              </p>
              <p class="font-mono text-gold uppercase text-[9px] tracking-[0.2em]">Brittany, NP-C · Founder</p>
            </div>
          </div>

          <!-- Copy -->
          <div class="reveal-right">
            <div class="flex items-center gap-4 mb-7">
              <div class="h-px bg-gold w-6"></div>
              <span class="font-mono text-[10px] tracking-[0.2em] uppercase text-gold">The Founder</span>
            </div>

            <h2 class="font-display font-light text-ink mb-6 leading-[1.05] tracking-[-0.01em]" style="font-size: clamp(32px, 3vw, 46px);">
              A nurse practitioner who decided to fix the problem herself.
            </h2>

            <p class="font-sans font-light text-[15px] leading-[1.8] text-ink-soft mb-5">
              Brittany, NP-C spent years in clinical practice watching patients struggle with the same problem: a skincare industry that prioritized marketing over medicine. Twelve-step routines, conflicting advice, and products formulated for aesthetics rather than efficacy.
            </p>
            <p class="font-sans font-light text-[15px] leading-[1.8] text-ink-soft mb-5">
              She partnered with a licensed cosmetic chemist to develop what didn't exist — a medical-grade, plant-based system that delivers real clinical results in under five minutes. Every formula is purity-tested. Every batch is produced locally in Louisiana, under full quality control.
            </p>
            <p class="font-sans font-light text-[15px] leading-[1.8] text-ink-soft mb-10">
              CFC is not a product line. It is a protocol — designed by someone who has seen, clinically, what skin actually needs.
            </p>

            <!-- Credentials -->
            <div class="border-t border-rule">
              {[
                ['NP-C Founded', 'Clinical knowledge, not a marketing department'],
                ['Chemist Formulated', 'Medical-grade efficacy, verified'],
                ['Purity-Tested', 'Every batch, every time'],
                ['Louisiana-Made', 'Local production, full quality control'],
              ].map(([label, desc]) => (
                <div class="flex items-start gap-4 py-4 border-b border-rule">
                  <div class="shrink-0 flex items-center justify-center mt-[3px] w-[16px] h-[16px] border border-gold rounded-full">
                    <svg class="text-gold" width="8" height="6" viewBox="0 0 10 8" fill="none" stroke="currentColor" stroke-width="1.5">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M1 4l2.5 2.5L9 1"/>
                    </svg>
                  </div>
                  <span class="font-sans font-light text-[14px] text-ink-soft">
                    <strong class="font-medium text-ink">{label}</strong> — {desc}
                  </span>
                </div>
              ))}
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- Family note -->
    <section class="bg-parchment py-[100px]">
      <div class="max-w-[1440px] mx-auto px-10">
        <div class="grid grid-cols-1 lg:grid-cols-[5fr_7fr] gap-16 lg:gap-24 items-center">
          <div class="reveal-left">
            <div class="flex items-center gap-4 mb-7">
              <div class="h-px bg-gold w-6"></div>
              <span class="font-mono text-[10px] tracking-[0.2em] uppercase text-gold">The Why</span>
            </div>
            <h2 class="font-display font-light text-ink leading-[1.08] tracking-[-0.01em] mb-6" style="font-size: clamp(34px, 3.5vw, 54px);">
              A system designed for the women she serves, and the family she is raising.
            </h2>
            <p class="font-sans font-light text-[15px] leading-[1.8] text-ink-soft">
              The same standards Brittany brings to patient care and motherhood inform every formula: simple routines, clean ingredients, and results that make sense in real life.
            </p>
          </div>

          <div class="reveal-right overflow-hidden aspect-[16/9] border border-rule bg-white">
            <Image
              src={brit4Img}
              alt="Brittany with her children"
              class="w-full h-full object-cover object-center"
              widths={[720, 1080, 1440, 2000]}
              sizes="(max-width: 1024px) 100vw, 58vw"
            />
          </div>
        </div>
      </div>
    </section>

  </main>
</Layout>
