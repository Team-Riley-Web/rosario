---
import { Image } from 'astro:assets';
import ProductCard from './ProductCard.astro';
import { getProductByHandle } from '../lib/shopify';
import cleanseImg from '../assets/images/imgi_13_tt-102_1500x.jpg';
import treatImg from '../assets/images/protect.jpg';
import protectImg from '../assets/images/imgi_27_alaina3.jpg';

const steps = [
  {
    number: '01',
    step: 'Cleanse',
    stepLabel: 'Step 01',
    headline: 'A clean slate, not a stripped one.',
    body: 'Gentle, plant-based cleansers that remove impurities without compromising your skin\'s natural barrier. Options include our Age Defying Brightening, NAD+ Bamboo Firming, and Jamin Jasmine formulas.',
    products: [
      { name: 'Age Defying Brightening Cleanser', handle: 'age-defying-brightening-cleanser', href: '/products/age-defying-brightening-cleanser' },
      { name: 'NAD+ Bamboo Firming Cleanser', handle: 'nad-bamboo-firming-cleanser', href: '/products/nad-bamboo-firming-cleanser' },
      { name: 'Jamin Jasmine Cleanser', handle: 'jamin-jasmine-cleanser', href: '/products/jamin-jasmine-cleanser' },
    ],
    image: cleanseImg,
    imageAlt: 'Woman cleansing face at sink with CFC products',
    imageRight: true,
  },
  {
    number: '02',
    step: 'Treat',
    stepLabel: 'Step 02',
    headline: 'Where clinical results happen.',
    body: 'The heart of the CFC system. Three hero treatments working in synergy to address pigmentation, oxidative damage, fine lines, and cellular hydration.',
    products: [
      { name: 'Apple Stem Wrinkle Eraser', handle: 'apple-stem-wrinkle-eraser', href: '/products/apple-stem-wrinkle-eraser' },
      { name: 'Color Correction C&E Serum', handle: 'color-correction-c-e-serum', href: '/products/color-correction-c-e-serum' },
      { name: 'Pure Hydration Hyaluronic Acid Serum', handle: 'pure-hydration-ha', href: '/products/pure-hydration-ha' },
    ],
    image: treatImg,
    imageAlt: 'Woman applying CFC treatment serum',
    imageRight: false,
  },
  {
    number: '03',
    step: 'Protect',
    stepLabel: 'Step 03',
    headline: 'Guard every result you\'ve earned.',
    body: 'Medical-grade SPF formulations that protect your skin investment and wear beautifully on all skin tones — no white cast, no compromise.',
    products: [
      { name: 'Pure Sun Defense SPF 50+', handle: 'pure-sun-defense-sunscreen', href: '/products/pure-sun-defense-sunscreen' },
      { name: 'Sun Kissed Protection Tinted SPF 30', handle: 'sun-kissed-protection-sunscreen', href: '/products/sun-kissed-protection-sunscreen' },
    ],
    image: protectImg,
    imageAlt: 'Woman at sink with CFC skincare routine',
    imageRight: true,
  },
];

const stepProducts = await Promise.all(
  steps.map(async (step) => {
    const products = await Promise.all(
      step.products.map(async (product) => ({
        product: await getProductByHandle(product.handle),
      }))
    );

    return products.filter((item) => item.product);
  })
);
---

<section id="system" class="bg-ink" x-data="{ activeStepModal: null }">

  <!-- Steps -->
  {steps.map(({ number, step, stepLabel, headline, body, products, image, imageAlt, imageRight }, i) => (
    <div
      class="reveal grid grid-cols-1 lg:grid-cols-2 lg:h-[650px] overflow-hidden"
      style={`border-top: 1px solid rgba(255,255,255,0.06); transition-delay: ${i * 80}ms;`}
    >

      <!-- Image (alternates sides) -->
      <div
        class={`relative overflow-hidden group h-[300px] lg:h-auto ${imageRight ? 'order-2' : 'order-2 lg:order-1'}`}
      >
        <Image
          src={image}
          alt={imageAlt}
          class="w-full h-full object-cover object-center transition-transform duration-[900ms] ease-[cubic-bezier(0.16,1,0.3,1)] group-hover:scale-[1.04]"
          widths={[600, 900, 1200]}
          sizes="50vw"
        />
      </div>

      <!-- Content -->
      <div
        class={`relative overflow-hidden flex flex-col justify-center px-8 py-12 lg:px-20 lg:py-[72px] ${imageRight ? 'order-1' : 'order-1 lg:order-2'}`}
      >
        <!-- Ghost number -->
        <span
          aria-hidden="true"
          class="absolute font-display font-light leading-none select-none pointer-events-none text-[rgba(255,255,255,0.06)]"
          style="font-size: 360px; right: -30px; bottom: -60px;"
        >{number}</span>

        <div class="relative max-w-[380px]">
          <!-- Step label -->
          <div class="flex items-center gap-4 mb-7">
            <div class="h-px bg-gold w-5"></div>
            <span class="font-mono text-[10px] tracking-[0.2em] uppercase text-gold">{step} — {stepLabel}</span>
          </div>

          <h3 class="font-display font-light text-white mb-5 leading-[1.1]" style="font-size: clamp(32px, 2.8vw, 44px);">
            {headline}
          </h3>

          <p class="font-sans font-light text-[14px] leading-[1.7] mb-8 text-[rgba(255,255,255,0.55)]">
            {body}
          </p>

          <ul class="mb-8 space-y-2">
            {products.map(p => (
              <li class="flex items-center gap-3 font-sans font-light text-[13px] text-[rgba(255,255,255,0.6)]">
                <span class="h-px bg-gold shrink-0 w-4"></span>
                <a href={p.href} class="transition-colors duration-200 hover:text-gold">
                  {p.name}
                </a>
              </li>
            ))}
          </ul>

          <button
            type="button"
            @click={`activeStepModal = ${i}`}
            class="link-arrow font-mono text-[10px] tracking-[0.18em] uppercase text-gold"
          >
            Shop {step}
            <svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
            </svg>
          </button>
        </div>
      </div>
    </div>
  ))}

  {steps.map(({ step, stepLabel, headline }, i) => (
    <div
      x-show={`activeStepModal === ${i}`}
      x-cloak
      x-transition:enter="transition ease-out duration-300"
      x-transition:enter-start="opacity-0"
      x-transition:enter-end="opacity-100"
      x-transition:leave="transition ease-in duration-200"
      x-transition:leave-start="opacity-100"
      x-transition:leave-end="opacity-0"
      @keydown.escape.window="activeStepModal = null"
      class="fixed inset-0 z-50 flex items-center justify-center bg-[rgba(0,0,0,0.62)] px-4 py-8"
      role="dialog"
      aria-modal="true"
      aria-labelledby={`step-products-title-${i}`}
    >
      <div class="absolute inset-0" @click="activeStepModal = null"></div>
      <div
        class="relative w-full max-w-6xl max-h-[90vh] overflow-y-auto bg-parchment shadow-strong"
        x-transition:enter="transition ease-out duration-300"
        x-transition:enter-start="opacity-0 translate-y-5 scale-[0.98]"
        x-transition:enter-end="opacity-100 translate-y-0 scale-100"
        x-transition:leave="transition ease-in duration-200"
        x-transition:leave-start="opacity-100 translate-y-0 scale-100"
        x-transition:leave-end="opacity-0 translate-y-3 scale-[0.98]"
      >
        <div class="sticky top-0 z-20 flex justify-end px-4 pt-4">
          <button
            type="button"
            @click="activeStepModal = null"
            class="size-10 border border-rule bg-white font-mono text-[14px] text-ink shadow-strong transition-colors duration-200 hover:border-ink"
            aria-label="Close"
          >
            &times;
          </button>
        </div>

        <div class="-mt-10 px-6 py-8 text-center sm:px-10 sm:py-10">
          <div class="mb-4 flex items-center justify-center gap-4">
            <span class="h-px w-5 bg-gold"></span>
            <span class="font-mono text-[10px] tracking-[0.2em] uppercase text-gold">{step} — {stepLabel}</span>
            <span class="h-px w-5 bg-gold"></span>
          </div>
          <h2
            id={`step-products-title-${i}`}
            class="font-display font-light leading-none text-ink"
            style="font-size: clamp(36px, 4vw, 58px);"
          >
            Shop {step}
          </h2>
          <p class="mx-auto mt-4 max-w-xl font-sans text-[13px] font-light leading-relaxed text-ink-soft">
            {headline}
          </p>
        </div>

        {stepProducts[i].length > 0 ? (
          <div class={`grid grid-cols-1 gap-px px-6 pb-6 sm:px-10 ${stepProducts[i].length === 2 ? 'mx-auto max-w-3xl sm:grid-cols-2' : 'sm:grid-cols-2 lg:grid-cols-3'}`}>
            {stepProducts[i].map(({ product }) => product && (
              <ProductCard product={product} />
            ))}
          </div>
        ) : (
          <div class="px-6 pb-10 text-center sm:px-10">
            <p class="font-sans text-[14px] font-light leading-relaxed text-ink-soft">
              These products are temporarily unavailable.
            </p>
          </div>
        )}

      </div>
    </div>
  ))}
</section>
