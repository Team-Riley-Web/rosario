---
import rosarioIconGold from '../assets/images/rosario-icon-gold.png';
import { Facebook, Heart, Instagram, Phone } from '@lucide/astro';

const shopLinks = [
  { label: 'Authentic Vintage Moretti', href: '/shop?filter=signature-moretti' },
  { label: 'Restored Vintage Millefiori', href: '/shop?filter=vintage-millefiori' },
  { label: 'Beads for Makers', href: '/shop?filter=beads-for-makers' },
  { label: 'Freshwater Pearl', href: '/shop?filter=freshwater-pearls' },
  { label: 'View All', href: '/shop' },
];

const aboutLinks = [
  { label: 'About Rosario', href: '/about' },
  { label: 'FAQ', href: '/faq' },
  { label: 'Contact', href: '/contact' },
  { label: 'Returns', href: '/returns' },
];

const contactLinks = [
  { label: '504-275-5222', href: 'tel:+15042755222', Icon: Phone },
  { label: 'Facebook', href: 'https://www.facebook.com/LakeviewPearls', Icon: Facebook },
  { label: 'Instagram', href: 'https://www.instagram.com/rosarioleonardimurano/', Icon: Instagram },
];

const shopDomain = import.meta.env.PUBLIC_SHOPIFY_STORE_DOMAIN || 'your-store.myshopify.com';
---

<footer class="site-footer">
  <div class="footer-grid">
    <div>
      <a href="/" class="footer-brand" aria-label="Rosario Leonardi, Home">
        <img src={rosarioIconGold.src} alt="" aria-hidden="true" class="footer-brand-icon" />
        <span class="footer-brand-name">Rosario Leonardi</span>
      </a>
      <p class="footer-brand-tag">
        One-of-a-kind Venetian glass jewelry, sourced through direct relationships in Venice and across Europe.
      </p>
      <form class="newsletter-form" id="newsletter-form" novalidate>
        <input class="newsletter-input" type="email" placeholder="Your email address" aria-label="Email address" id="newsletter-email" required />
        <button class="newsletter-btn" type="submit">Join</button>
      </form>
      <p class="newsletter-thanks" id="newsletter-thanks">Thank you. Welcome to the list.</p>
    </div>

    <div>
      <div class="footer-nav-title">Shop</div>
      <nav class="footer-nav" aria-label="Shop navigation">
        {shopLinks.map(({ label, href }) => <a href={href}>{label}</a>)}
      </nav>
    </div>

    <div>
      <div class="footer-nav-title">About</div>
      <nav class="footer-nav" aria-label="Company navigation">
        {aboutLinks.map(({ label, href }) => <a href={href}>{label}</a>)}
      </nav>
    </div>

    <div>
      <div class="footer-nav-title">Contact</div>
      <nav class="footer-nav footer-contact" aria-label="Contact and social links">
        {contactLinks.map(({ label, href, Icon }) => (
          <a href={href} target={href.startsWith('http') ? '_blank' : undefined} rel={href.startsWith('http') ? 'noopener' : undefined}>
            <Icon class="footer-contact-icon h-3.5 w-3.5" aria-hidden="true" />
            <span>{label}</span>
          </a>
        ))}
      </nav>
    </div>
  </div>

  <div class="footer-bottom">
    <span class="footer-copy">© {new Date().getFullYear()} Rosario Leonardi. All rights reserved.</span>
    <div class="footer-legal">
      <a href="/privacy">Privacy</a>
      <a href="/terms">Terms</a>
      <a href="https://teamrileyweb.com/" target="_blank" rel="noopener" class="footer-credit">
        <span>Crafted with</span>
        <Heart class="footer-credit-heart h-3.5 w-3.5 fill-current" aria-label="love" />
        <span>by Team Riley</span>
      </a>
    </div>
  </div>
</footer>

<script define:vars={{ shopDomain }}>
  const newsletterForm = document.getElementById('newsletter-form') as HTMLFormElement | null;
  const newsletterThanks = document.getElementById('newsletter-thanks');

  newsletterForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const input = document.getElementById('newsletter-email') as HTMLInputElement | null;
    const email = input?.value.trim() ?? '';
    if (!email || !email.includes('@')) return;

    const btn = newsletterForm.querySelector('button[type="submit"]') as HTMLButtonElement | null;
    if (btn) {
      btn.textContent = 'Joining...';
      btn.disabled = true;
    }

    await fetch(`https://${shopDomain}/contact`, {
      method: 'POST',
      mode: 'no-cors',
      headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
      body: new URLSearchParams({
        form_type: 'customer',
        utf8: '✓',
        'contact[email]': email,
        'contact[tags]': 'newsletter',
      }),
    });

    newsletterForm.style.display = 'none';
    if (newsletterThanks) newsletterThanks.style.display = 'block';
  });
</script>

<style>
  .site-footer {
    background: var(--bg);
    border-top: 1px solid var(--border);
    padding: var(--space-8) 2.5rem 2.5rem;
  }
  .footer-grid {
    max-width: 1180px;
    margin: 0 auto var(--space-7);
    display: grid;
    gap: var(--space-7);
  }
  .footer-brand {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 1rem;
  }
  .footer-brand-icon {
    width: 28px;
    height: 34px;
    object-fit: contain;
    flex-shrink: 0;
  }
  .footer-brand-name {
    font-family: var(--font-wordmark);
    font-size: 28px;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--fg);
    line-height: 1;
  }
  .footer-brand-tag {
    font-size: 13px;
    font-weight: 300;
    line-height: var(--leading-body);
    color: var(--fg-sub);
    margin-bottom: var(--space-6);
    max-width: 300px;
  }
  .newsletter-form {
    display: flex;
    max-width: 400px;
  }
  .newsletter-input {
    flex: 1;
    min-width: 0;
    padding: var(--space-3) var(--space-4);
    background: var(--surface-lift);
    border: 1px solid var(--border-lift);
    border-right: none;
    border-radius: var(--radius-sharp) 0 0 var(--radius-sharp);
    color: var(--fg);
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 300;
    transition: border-color 0.2s;
  }
  .newsletter-input::placeholder { color: var(--muted); }
  .newsletter-input:focus { border-color: var(--accent); }
  .newsletter-btn {
    padding: var(--space-3) 1.25rem;
    background: var(--accent);
    color: var(--bg);
    border: 1px solid var(--accent);
    border-radius: 0 var(--radius-sharp) var(--radius-sharp) 0;
    font-family: var(--font-label);
    font-size: 10px;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    white-space: nowrap;
    transition: background 0.2s, border-color 0.2s;
  }
  .newsletter-btn:hover { background: var(--accent-light); border-color: var(--accent-light); }
  .newsletter-thanks {
    display: none;
    font-family: var(--font-label);
    font-size: 10px;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--accent);
    padding: var(--space-3) 0;
  }
  .footer-nav-title {
    font-family: var(--font-label);
    font-size: 10px;
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 1rem;
  }
  .footer-nav a {
    display: block;
    font-size: 13px;
    font-weight: 300;
    color: var(--fg-sub);
    padding: 6px 0;
    transition: color 0.2s;
  }
  .footer-nav a:hover { color: var(--accent); }
  .footer-contact a {
    display: flex;
    align-items: center;
    gap: 0.65rem;
  }
  .footer-contact-icon {
    color: var(--accent);
    flex-shrink: 0;
  }
  .footer-bottom {
    max-width: 1180px;
    margin: 0 auto;
    padding-top: 2rem;
    border-top: 1px solid var(--border);
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
  }
  .footer-copy,
  .footer-legal a {
    font-family: var(--font-label);
    font-size: 9px;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--muted);
  }
  .footer-legal {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1.5rem;
  }
  .footer-legal a:hover { color: var(--fg-sub); }
  .footer-credit {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    white-space: nowrap;
  }
  .footer-credit-heart {
    color: var(--accent);
  }
  @media (min-width: 768px) {
    .footer-grid { grid-template-columns: 1.2fr 1fr 0.8fr 0.8fr; gap: 4rem; }
  }
  @media (max-width: 767px) {
    .site-footer { padding: 3rem 1.5rem 2rem; }
    .footer-grid {
      justify-items: center;
      text-align: center;
    }
    .footer-grid > div:nth-child(2),
    .footer-grid > div:nth-child(3),
    .footer-brand-tag {
      display: none;
    }
    .footer-contact a {
      justify-content: center;
    }
    .footer-brand {
      justify-content: center;
      flex-direction: column;
      gap: 0.75rem;
    }
    .newsletter-form { max-width: none; }
    .footer-bottom {
      flex-direction: column;
      justify-content: center;
      text-align: center;
    }
    .footer-legal {
      justify-content: center;
      gap: 1rem;
    }
  }
</style>
