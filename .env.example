SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_CHECKOUT_DOMAIN=your-store.myshopify.com
SHOPIFY_API_VERSION=2024-01
SHOPIFY_STOREFRONT_TOKEN=

PUBLIC_SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
PUBLIC_SHOPIFY_CHECKOUT_DOMAIN=your-store.myshopify.com
PUBLIC_SHOPIFY_API_VERSION=2024-01
PUBLIC_SHOPIFY_STOREFRONT_TOKEN=

# Comma-separated custom storefront domains. Checkout URL normalization uses
# this to avoid sending checkout traffic to the static headless host.
HEADLESS_DOMAINS=example.com,www.example.com
PUBLIC_HEADLESS_DOMAINS=example.com,www.example.com

# Use only for local/CI test builds that should not call Shopify.
SHOPIFY_USE_MOCKS=false
PUBLIC_SHOPIFY_USE_MOCKS=false
