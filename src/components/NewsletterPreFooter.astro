---
---

<section class="bg-parchment pb-24">
  <div class="h-px bg-gold w-full"></div>

  <div class="max-w-[1440px] mx-auto pt-24 px-10">
    <div class="max-w-[760px] mx-auto text-center">
      <div class="reveal mx-auto">
        <h2 class="font-display font-light text-ink leading-none tracking-[-0.02em] mb-5" style="font-size: clamp(38px, 4.2vw, 62px);">
          Let's Stay in Touch
        </h2>
        <p class="font-sans font-light text-[14px] leading-[1.75] text-ink-soft max-w-[560px] mx-auto">
          Be the first to know about new collections, exclusive offers, and skincare insights.
        </p>
      </div>

      <div class="reveal mt-10">
        <form
          id="global-newsletter-form"
          class="grid grid-cols-1 sm:grid-cols-[1fr_auto] gap-2 max-w-[620px] mx-auto"
          novalidate
        >
          <input
            type="email"
            name="email"
            placeholder="Your email address"
            required
            class="bg-white border border-rule font-mono text-[11px] tracking-[0.08em] text-ink placeholder:text-ink-soft outline-none transition-colors focus:border-gold px-5 py-4 text-center sm:text-left"
          />
          <button
            type="submit"
            class="font-mono text-[10px] tracking-[0.18em] uppercase px-8 py-4 bg-ink text-white transition-colors duration-200 hover:bg-gold-deep whitespace-nowrap"
          >
            Subscribe
          </button>
        </form>

        <p id="global-newsletter-msg" class="mt-4 font-mono text-[10px] tracking-[0.1em] uppercase hidden text-ink-soft"></p>
      </div>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('global-newsletter-form') as HTMLFormElement | null;
  const msg = document.getElementById('global-newsletter-msg');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const email = (form.elements.namedItem('email') as HTMLInputElement).value.trim();
    if (!email) return;

    const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    btn.textContent = 'Subscribing...';
    btn.disabled = true;

    try {
      await fetch('https://www.cfcskincare.shop/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: new URLSearchParams({
          form_type: 'customer',
          'contact[email]': email,
          'contact[tags]': 'newsletter',
        }),
      });

      if (msg) {
        msg.textContent = 'You are in. Welcome to the CFC community.';
        msg.classList.remove('hidden');
      }
      form.reset();
    } catch {
      if (msg) {
        msg.textContent = 'Something went wrong. Please email us directly.';
        msg.classList.remove('hidden');
      }
    } finally {
      btn.textContent = 'Subscribe';
      btn.disabled = false;
    }
  });
</script>
