---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
---

<Layout
  title="About This Starter — Astro Shopify Starter"
  description="Setup notes for the reusable Astro Shopify starter template."
>
  <Nav />
  <main>
    <section class="bg-ink px-10 pb-24 pt-40 text-white">
      <div class="mx-auto max-w-[960px]">
        <div class="mb-8 flex items-center gap-4">
          <div class="h-px w-6 bg-gold"></div>
          <span class="font-mono text-[10px] uppercase tracking-[0.2em] text-gold">Starter Notes</span>
        </div>
        <h1 class="mb-7 font-display text-[48px] font-light leading-none tracking-normal md:text-[76px]">
          Build the store on top of this foundation.
        </h1>
        <p class="max-w-[680px] font-sans text-[16px] font-light leading-[1.8] text-white/65">
          This template keeps the reusable headless Shopify pieces and leaves the brand, content model, imagery, and merchandising strategy open for each new storefront.
        </p>
      </div>
    </section>

    <section class="bg-parchment px-10 py-24">
      <div class="mx-auto grid max-w-[1120px] gap-px border border-rule bg-rule md:grid-cols-2">
        {[
          ['Configure Shopify', 'Copy .env.example to .env, set the myshopify.com domain, checkout domain, API version, and Storefront API token.'],
          ['Replace Content', 'Update page copy, legal policies, imagery, favicon, and Open Graph artwork for the target store.'],
          ['Tune Catalog Rules', 'Adjust collection handles, product filtering, related products, and selling-plan display to match the store.'],
          ['Verify Checkout', 'Run unit tests and Playwright shopping-flow tests before launch, then confirm checkout URLs in the deployed environment.'],
        ].map(([title, body]) => (
          <article class="bg-white p-8">
            <h2 class="mb-3 font-display text-[26px] font-normal leading-tight text-ink">{title}</h2>
            <p class="font-sans text-[14px] font-light leading-[1.8] text-ink-soft">{body}</p>
          </article>
        ))}
      </div>
    </section>
  </main>
</Layout>
