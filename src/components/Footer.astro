---
import { Image } from 'astro:assets';
import cfcLogo from '../assets/images/cfc-logo.png';

const shopLinks = [
  { label: 'All Products', href: '/shop' },
  { label: 'Cleansers', href: '/shop' },
  { label: 'Treatments', href: '/shop' },
  { label: 'Sun Protection', href: '/shop' },
];

const learnLinks = [
  { label: 'The System', href: '/#system' },
  { label: 'About CFC', href: '/#about' },
  { label: 'Consultation', href: '/#contact' },
  { label: 'Subscribe & Save', href: 'https://www.cfcskincare.shop' },
];
---

<footer class="bg-ink">

  <!-- Gold accent line -->
  <div style="height: 1px; background: linear-gradient(to right, oklch(64% 0.115 72 / 0.7), transparent 55%);"></div>

  <div class="max-w-[1440px] mx-auto px-10 pt-20 pb-11">

    <!-- Main grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-[2fr_1fr_1fr_1.5fr] gap-12 lg:gap-16 mb-16">

      <!-- Brand: large standalone logo -->
      <div class="flex flex-col">
        <a href="/" class="block mb-7 shrink-0">
          <Image
            src={cfcLogo}
            alt="CFC Skincare"
            width={96}
            height={96}
            densities={[1, 2, 3]}
            class="w-24 h-24 rounded-full object-cover"
          />
        </a>
        <div class="h-px bg-gold mb-4 w-6"></div>
        <p class="font-mono text-[10px] tracking-[0.28em] uppercase" style="color: rgba(255,255,255,0.35);">
          CFC Skincare
        </p>
      </div>

      <!-- Shop -->
      <div>
        <h4 class="font-mono text-[9px] tracking-[0.22em] uppercase mb-6" style="color: rgba(255,255,255,0.25);">Shop</h4>
        <ul class="space-y-3.5">
          {shopLinks.map(({ label, href }) => (
            <li>
              <a
                href={href}
                class="font-sans font-light text-[13px] transition-colors duration-200"
                style="color: rgba(255,255,255,0.5);"
                onmouseover="this.style.color='oklch(80% 0.08 78)'"
                onmouseout="this.style.color='rgba(255,255,255,0.5)'"
              >{label}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Learn -->
      <div>
        <h4 class="font-mono text-[9px] tracking-[0.22em] uppercase mb-6" style="color: rgba(255,255,255,0.25);">Learn</h4>
        <ul class="space-y-3.5">
          {learnLinks.map(({ label, href }) => (
            <li>
              <a
                href={href}
                class="font-sans font-light text-[13px] transition-colors duration-200"
                style="color: rgba(255,255,255,0.5);"
                onmouseover="this.style.color='oklch(80% 0.08 78)'"
                onmouseout="this.style.color='rgba(255,255,255,0.5)'"
              >{label}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Connect -->
      <div>
        <h4 class="font-mono text-[9px] tracking-[0.22em] uppercase mb-6" style="color: rgba(255,255,255,0.25);">Connect</h4>

        <!-- Address -->
        <address class="not-italic mb-5 leading-[1.8]" style="color: rgba(255,255,255,0.45);">
          <p class="font-sans font-light text-[13px]">Louisiana, United States</p>
        </address>

        <!-- Phone -->
        <a
          href="tel:+15551234567"
          class="font-mono text-[12px] tracking-[0.08em] block mb-8 transition-colors duration-200"
          style="color: rgba(255,255,255,0.45);"
          onmouseover="this.style.color='oklch(80% 0.08 78)'"
          onmouseout="this.style.color='rgba(255,255,255,0.45)'"
        >+1 (555) 123-4567</a>

        <!-- Social icons -->
        <div class="flex gap-3">

          <!-- Instagram -->
          <a
            href="https://www.instagram.com/cfcskincare"
            target="_blank"
            rel="noopener"
            aria-label="CFC Skincare on Instagram"
            class="flex items-center justify-center transition-all duration-200 w-10 h-10"
            style="border: 1px solid rgba(255,255,255,0.1); color: rgba(255,255,255,0.45);"
            onmouseover="this.style.borderColor='oklch(64% 0.115 72)'; this.style.color='oklch(64% 0.115 72)'"
            onmouseout="this.style.borderColor='rgba(255,255,255,0.1)'; this.style.color='rgba(255,255,255,0.45)'"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <rect x="2" y="2" width="20" height="20" rx="5"/>
              <circle cx="12" cy="12" r="4"/>
              <circle cx="17.5" cy="6.5" r="0.75" fill="currentColor" stroke="none"/>
            </svg>
          </a>

          <!-- Facebook -->
          <a
            href="https://www.facebook.com/cfcskincare"
            target="_blank"
            rel="noopener"
            aria-label="CFC Skincare on Facebook"
            class="flex items-center justify-center transition-all duration-200 w-10 h-10"
            style="border: 1px solid rgba(255,255,255,0.1); color: rgba(255,255,255,0.45);"
            onmouseover="this.style.borderColor='oklch(64% 0.115 72)'; this.style.color='oklch(64% 0.115 72)'"
            onmouseout="this.style.borderColor='rgba(255,255,255,0.1)'; this.style.color='rgba(255,255,255,0.45)'"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
              <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
            </svg>
          </a>

        </div>
      </div>
    </div>

    <!-- Bottom bar -->
    <div
      class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 pt-8"
      style="border-top: 1px solid rgba(255,255,255,0.06);"
    >
      <p class="font-mono text-[9px] tracking-[0.15em] uppercase" style="color: rgba(255,255,255,0.2);">
        © {new Date().getFullYear()} CFC Skincare · Locally made in Louisiana
      </p>
      <div class="flex gap-6">
        {[
          ['Privacy', 'https://www.cfcskincare.shop/policies/privacy-policy'],
          ['Terms', 'https://www.cfcskincare.shop/policies/terms-of-service'],
          ['Returns', 'https://www.cfcskincare.shop/policies/refund-policy'],
        ].map(([label, href]) => (
          <a
            href={href}
            class="font-mono text-[9px] tracking-[0.15em] uppercase transition-colors duration-200"
            style="color: rgba(255,255,255,0.2);"
            onmouseover="this.style.color='rgba(255,255,255,0.5)'"
            onmouseout="this.style.color='rgba(255,255,255,0.2)'"
          >{label}</a>
        ))}
      </div>
    </div>

  </div>
</footer>
