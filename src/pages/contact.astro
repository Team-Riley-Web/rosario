---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
---

<Layout
  title="Contact — Astro Shopify Starter"
  description="A starter contact page with a Netlify-ready form."
>
  <Nav />
  <main>
    <section class="bg-ink px-10 pb-24 pt-40 text-white">
      <div class="mx-auto max-w-[960px]">
        <div class="mb-8 flex items-center gap-4">
          <div class="h-px w-6 bg-gold"></div>
          <span class="font-mono text-[10px] uppercase tracking-[0.2em] text-gold">Contact</span>
        </div>
        <h1 class="mb-7 font-display text-[48px] font-light leading-none tracking-normal md:text-[76px]">
          Starter contact form.
        </h1>
        <p class="max-w-[620px] font-sans text-[16px] font-light leading-[1.8] text-white/65">
          Replace this page with the target store's support, wholesale, press, or service workflow.
        </p>
      </div>
    </section>

    <section class="bg-parchment px-10 py-24">
      <div class="mx-auto grid max-w-[1120px] gap-12 lg:grid-cols-[0.8fr_1.2fr]">
        <aside>
          <h2 class="mb-5 font-display text-[34px] font-light leading-tight text-ink">Keep the form or wire in your helpdesk.</h2>
          <p class="font-sans text-[14px] font-light leading-[1.8] text-ink-soft">
            The default form is Netlify-compatible. Update fields, routing, and copy before using this in a production storefront.
          </p>
        </aside>

        <form
          name="contact"
          method="POST"
          data-netlify="true"
          netlify-honeypot="bot-field"
          class="grid gap-5 border border-rule bg-white p-6 sm:p-10"
        >
          <input type="hidden" name="form-name" value="contact" />
          <p class="hidden"><label>Do not fill this out: <input name="bot-field" /></label></p>

          <label class="grid gap-2">
            <span class="font-mono text-[10px] uppercase tracking-[0.18em] text-ink-soft">Name</span>
            <input name="name" required class="border border-rule px-4 py-3 font-sans text-sm outline-none focus:border-gold" />
          </label>
          <label class="grid gap-2">
            <span class="font-mono text-[10px] uppercase tracking-[0.18em] text-ink-soft">Email</span>
            <input type="email" name="email" required class="border border-rule px-4 py-3 font-sans text-sm outline-none focus:border-gold" />
          </label>
          <label class="grid gap-2">
            <span class="font-mono text-[10px] uppercase tracking-[0.18em] text-ink-soft">Message</span>
            <textarea name="message" rows="6" required class="border border-rule px-4 py-3 font-sans text-sm outline-none focus:border-gold"></textarea>
          </label>
          <button class="justify-self-start bg-ink px-7 py-3 font-mono text-[10px] uppercase tracking-[0.18em] text-white transition-colors hover:bg-gold-deep">
            Send Message
          </button>
        </form>
      </div>
    </section>
  </main>
</Layout>
