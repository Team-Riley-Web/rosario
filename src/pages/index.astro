---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import ProductsSection from '../components/ProductsSection.astro';
import heroImage from '../assets/images/model6.png';
import heroVideo from '../assets/videos/Rosario.mp4';
import necklacesImage from '../assets/images/necklace.png';
import earringsImage from '../assets/images/earring.png';
import braceletsImage from '../assets/images/bracelet.png';
import ringsImage from '../assets/images/ring.png';
import beadsImage from '../assets/images/model2.avif';
import authenticityImage from '../assets/images/model8.png';
import personalImage from '../assets/images/lisa.png';
import giftImage from '../assets/images/gift.png';
import rosarioIcon from '../assets/images/rosario-icon.png';
import marbleImage from '../assets/images/marble.jpg';
import signatureImage from '../assets/images/signature.png';

const trustItems = [
  'Direct Partnership with Artisans',
  'Lifetime Warranty Against Defects',
  'One-of-a-Kind - Never Restocked',
  'Personally Sourced From Venice',
];

const collections = [
  {
    title: 'Necklaces',
    body: 'Statement necklaces hand-strung with authentic Murano glass beads. Each piece, an unrepeatable arrangement of color and light.',
    href: '/shop?filter=necklaces',
    image: necklacesImage,
    alt: 'Model wearing a bold Murano glass necklace',
  },
  {
    title: 'Earrings',
    body: 'Drop earrings and studs set with Millefiori beads and lampwork glass. Weightless, vivid, impossible to ignore.',
    href: '/shop?filter=earrings',
    image: earringsImage,
    alt: 'Murano glass earrings styled in warm natural light',
  },
  {
    title: 'Bracelets',
    body: 'Wrist pieces in vintage Millefiori, signature beads, and freshwater pearl. Worn alone or layered.',
    href: '/shop?filter=bracelets',
    image: braceletsImage,
    alt: 'Murano glass bracelet and jewelry styling',
  },
  {
    title: 'Rings',
    body: 'Adjustable rings set with single signature beads: cobalt, amber, teal. Understated or bold, depending on the glass.',
    href: '/shop?filter=rings',
    image: ringsImage,
    alt: 'Murano glass ring styling',
  },
];
---

<Layout
  title="Rosario Leonardi Murano Glass"
  description="One-of-a-kind Murano glass jewelry and beads sourced through direct Venetian and European relationships."
>
  <Nav homeInitialMinimal />
  <main>
    <section id="hero">
      <video
        class="hero-img"
        autoplay
        muted
        loop
        playsinline
        preload="metadata"
        poster={heroImage.src}
        aria-hidden="true"
      >
        <source src={heroVideo} type="video/mp4" />
      </video>
      <div class="hero-overlay" aria-hidden="true"></div>

      <div class="hero-content">
        <div class="hero-center">
          <div class="eyebrow">
            <span class="eyebrow-rule" aria-hidden="true"></span>
            <span class="eyebrow-text">Rosario Leonardi</span>
            <span class="eyebrow-rule" aria-hidden="true"></span>
          </div>
          <h1 class="hero-h1">Be Bold</h1>
          <a href="/shop" class="btn-primary">Shop Now <span aria-hidden="true">→</span></a>
        </div>
      </div>
    </section>

    <div class="trust-bar trust-bar--white">
      <div class="trust-grid">
        {trustItems.map((item) => (
          <div class="trust-item">
            <span class="trust-check" aria-hidden="true">✓</span>
            <p class="trust-label">{item}</p>
          </div>
        ))}
      </div>
    </div>

    <section class="section section--white letter-section" data-section="letter-from-lisa">
      <img src={rosarioIcon.src} alt="" class="letter-mark letter-mark--left" aria-hidden="true" />
      <img src={rosarioIcon.src} alt="" class="letter-mark letter-mark--right" aria-hidden="true" />
      <div class="inner">
        <div class="auth-editorial">
          <div class="auth-editorial-head reveal">
            <div class="eyebrow centered">
              <span class="eyebrow-rule" aria-hidden="true"></span>
              <span class="eyebrow-text">From the Founder</span>
              <span class="eyebrow-rule" aria-hidden="true"></span>
            </div>
            <h2 class="auth-headline">A Letter From Lisa</h2>
          </div>
          <!--<div class="auth-img reveal reveal-delay-1">-->
          <!--  <img-->
          <!--    src={authenticityImage.src}-->
          <!--    alt="Rosario Leonardi Murano glass jewelry worn in warm natural light"-->
          <!--    class="product-img"-->
          <!--    loading="lazy"-->
          <!--  />-->
          <!--</div>-->
          <div class="auth-copy reveal reveal-delay-2">
            <p>I didn't set out to sell jewelry. I fell in love with Murano glass on a trip to Venice - the way light moves through it, the way no two pieces are ever quite the same. I started collecting. Then restoring. Then, slowly, sourcing pieces directly from people in Venice who actually make this glass by hand, the way it's been made for centuries.</p>
            <p>Most of what you'll find online calling itself "Murano glass" isn't. It's imported, mass-produced, and dressed up with the right words. I got tired of watching people get fooled by that - and I got tired of seeing real Murano glass treated like it's interchangeable with the fakes.</p>
            <p>Everything here is real. Sourced through people I actually know. Restored by my own hands when it's vintage. Backed for life, because I stand behind what I sell.</p>
            <p>If you're here, I'm guessing you already know the difference matters. Let's find you something real.</p>
            <div class="auth-signature">
              <img src={signatureImage.src} alt="Lisa" loading="lazy" />
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="section" data-section="collections">
      <div class="inner--wide">
        <div class="collections-header reveal">
          <div class="eyebrow">
            <span class="eyebrow-rule" aria-hidden="true"></span>
            <span class="eyebrow-text">Collections</span>
          </div>
          <h2 class="collections-h2">One-of-a-Kind, in Every Form</h2>
        </div>

        <div class="coll-grid">
          {collections.map((collection, index) => (
            <article class={`coll-card reveal reveal-delay-${Math.min(index, 3)}`}>
              <a href={collection.href} class="coll-img-wrap" aria-label={`Shop ${collection.title}`}>
                <img
                  src={collection.image.src}
                  alt={collection.alt}
                  class="product-img"
                  loading="lazy"
                />
              </a>
              <div class="coll-body">
                <h3 class="coll-title">{collection.title}</h3>
                <p class="coll-desc">{collection.body}</p>
                <a href={collection.href} class="link-arrow">
                  Shop {collection.title}
                  <span aria-hidden="true">→</span>
                </a>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section section--white personal-story-section" data-section="personal-story">
      <div class="inner">
        <div class="personal-grid">
          <div class="personal-img reveal">
            <img
                src={personalImage.src}
                alt="Lisa, founder of Rosario Leonardi"
                class="product-img"
                loading="lazy"
            />
          </div>
          <div class="personal-copy reveal reveal-delay-1">
            <h2>You're Not Buying From a Faceless Storefront.</h2>
            <p>Have a question before you buy? Fill out the contact form and I will personally call you back. Whether you're choosing a gift, building a collection, or sourcing materials for your own work, I am here to help.</p>
            <div class="personal-btns">
              <a href="/contact" class="btn-primary">Get Gift Guidance</a>
              <a href="/contact" class="btn-ghost">Ask a Question</a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <ProductsSection />

    <section class="section section--white" data-section="gift">
      <div class="inner">
        <div class="gift-grid">
          <div class="gift-copy reveal">
            <h2>Need a Gift That Actually Feels Personal?</h2>
            <p>I'll get on the phone with you, learn who she is, and help you find the piece she'll genuinely love. Arrives beautifully boxed with a gold label. Add a gift bow if you'd like.</p>
            <a href="/contact" class="btn-primary">Get Gift Help</a>
          </div>
          <div class="gift-img reveal reveal-delay-1">
            <img
                src={giftImage.src}
                alt="Statement Murano glass jewelry styled for a personal gift"
                class="product-img"
                loading="lazy"
            />
          </div>
        </div>
      </div>
    </section>

    <!--<section class="section section&#45;&#45;surface" data-section="meet-the-beads">-->
    <!--  <div class="inner">-->
    <!--    <div class="beads-editorial">-->
    <!--      <div class="beads-editorial-head reveal">-->
    <!--        <div class="eyebrow centered">-->
    <!--          <span class="eyebrow-rule" aria-hidden="true"></span>-->
    <!--          <span class="eyebrow-text">Meet the Beads</span>-->
    <!--          <span class="eyebrow-rule" aria-hidden="true"></span>-->
    <!--        </div>-->
    <!--        <h2>Venetian glass with a name behind it.</h2>-->
    <!--      </div>-->
    <!--      <div class="beads-editorial-img reveal reveal-delay-1">-->
    <!--        <img-->
    <!--          src={authenticityImage.src}-->
    <!--          alt="Colorful Murano Millefiori glass beads close-up"-->
    <!--          class="product-img"-->
    <!--          loading="lazy"-->
    <!--        />-->
    <!--      </div>-->
    <!--      <div class="beads-editorial-copy reveal reveal-delay-2">-->
    <!--        <p>On the island of Murano, a short boat ride from Venice, a small number of families have been making glass beads for over seven centuries. Ercole Moretti is one of the last.</p>-->
    <!--        <p>That direct relationship matters. It is how I can tell you where the glass came from, why it is different, and why each piece deserves more than a generic "Murano-style" label.</p>-->
    <!--        <a href="/about" class="link-arrow">Read the Story <span aria-hidden="true">→</span></a>-->
    <!--      </div>-->
    <!--    </div>-->
    <!--  </div>-->
    <!--</section>-->

    <section class="section cta-strip bg-charcoal" data-section="cta">
      <div class="cta-flex">
        <div class="cta-text">
          <h2>Be Bold. Buy Now.</h2>
          <p>Every piece is one-of-a-kind. Once it's gone, it's gone.</p>
        </div>
        <a href="/shop" class="btn-primary btn-primary--accent">Shop the Collection <span aria-hidden="true">→</span></a>
      </div>
    </section>
  </main>
</Layout>

<style>
  #hero {
    position: relative;
    min-height: 90vh;
    display: flex;
    align-items: flex-end;
    padding: 8rem 0 5rem;
    overflow: hidden;
    background: var(--bg);
  }
  .hero-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 22%;
  }
  .hero-overlay {
    position: absolute;
    inset: 0;
    background: var(--hero-overlay);
  }
  .hero-content {
    position: relative;
    z-index: 10;
    max-width: 1440px;
    width: 100%;
    margin: 0 auto;
    padding: 0 2.5rem;
  }
  .hero-center {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    width: 100%;
    margin: 0 auto;
  }
  .hero-center .eyebrow {
    justify-content: center;
    margin-bottom: 1.25rem;
  }
  .hero-h1 {
    font-family: var(--font-display);
    font-weight: 300;
    line-height: var(--leading-display);
    letter-spacing: var(--tracking-normal);
    font-size: var(--text-display);
    color: var(--fg);
    margin-bottom: 2rem;
  }
  .trust-bar {
    background: var(--surface);
    border-bottom: 1px solid var(--border);
  }
  .trust-grid {
    max-width: 1440px;
    margin: 0 auto;
    padding: 0 2.5rem;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
  }
  .trust-item {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 1.5rem 2rem;
    border-right: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    min-height: 96px;
  }
  .trust-item:nth-child(2n) { border-right: none; }
  .trust-check {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    border: 1px solid var(--accent);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-label);
    font-size: 11px;
    color: var(--accent);
    flex-shrink: 0;
  }
  .trust-label {
    font-family: var(--font-label);
    font-size: 10px;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--fg-sub);
    line-height: 1.5;
  }
  .trust-bar--white {
    background: white;
    border-bottom-color: var(--light-border);
  }
  .trust-bar--white .trust-item { border-color: var(--light-border); }
  .trust-bar--white .trust-check {
    border-color: var(--accent);
    color: var(--accent);
  }
  .trust-bar--white .trust-label { color: oklch(35% 0.010 255); }
  .letter-section {
    position: relative;
    overflow: hidden;
    background-image: var(--letter-bg-image);
    background-size: cover;
    background-position: center;
  }
  .letter-section::before {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 0;
    background: oklch(99% 0.003 240 / 0.85);
    pointer-events: none;
  }
  .letter-section .inner {
    position: relative;
    z-index: 2;
  }
  .letter-mark {
    --mark-flip: 1;
    position: absolute;
    top: 50%;
    z-index: 1;
    width: clamp(260px, 32vw, 480px);
    opacity: 0.05;
    transform: translateY(-50%) scaleX(var(--mark-flip));
    pointer-events: none;
    user-select: none;
  }
  .letter-mark--left {
    --mark-flip: -1;
    left: max(-8rem, calc((100vw - 1180px) / 2 - 14rem));
  }
  .letter-mark--right {
    right: max(-8rem, calc((100vw - 1180px) / 2 - 14rem));
  }
  .auth-editorial {
    position: relative;
    isolation: isolate;
    display: grid;
    gap: 3rem;
    max-width: 840px;
    margin: 0 auto;
  }
  .letter-section .auth-editorial::before {
    content: "";
    position: absolute;
    z-index: 0;
    inset: -3rem -5rem;
    background: radial-gradient(
      ellipse at center,
      oklch(99% 0.003 240) 0%,
      oklch(99% 0.003 240 / 0.94) 42%,
      oklch(99% 0.003 240 / 0) 74%
    );
    pointer-events: none;
  }
  .letter-section .auth-editorial > * {
    position: relative;
    z-index: 1;
  }
  .auth-editorial-head {
    text-align: center;
  }
  .auth-headline,
  .collections-h2,
  .beads-editorial-head h2,
  .personal-copy h2,
  .gift-copy h2,
  .cta-text h2 {
    font-family: var(--font-display);
    font-weight: 300;
    line-height: var(--leading-display);
    letter-spacing: var(--tracking-normal);
    text-wrap: balance;
  }
  .auth-headline {
    font-size: var(--text-h2);
    color: var(--fg);
    max-width: 840px;
    margin: 0 auto;
    text-align: center;
  }
  .auth-img,
  .coll-img-wrap,
  .beads-editorial-img,
  .personal-img,
  .gift-img {
    overflow: hidden;
  }
  .coll-img-wrap {
    border-radius: var(--radius-sharp);
  }
  .personal-img .product-img { aspect-ratio: 4 / 5; }
  .auth-img .product-img,
  .beads-editorial-img .product-img { aspect-ratio: 16 / 9; }
  .coll-img-wrap .product-img {
    aspect-ratio: 4 / 3;
    transition: transform 0.8s cubic-bezier(0.16,1,0.3,1);
  }
  .gift-img .product-img { aspect-ratio: 4 / 3; }
  .auth-copy p,
  .beads-editorial-copy p,
  .personal-copy p,
  .gift-copy p {
    font-size: 16px;
    font-weight: 300;
    line-height: var(--leading-loose);
    color: var(--fg-sub);
    margin-bottom: 1.5rem;
    text-wrap: pretty;
  }
  .auth-copy p:last-of-type,
  .beads-editorial-copy p:last-of-type {
    margin-bottom: 2rem;
  }
  .auth-copy p:last-of-type {
    margin-bottom: 0;
  }
  .auth-copy {
    max-width: 600px;
    margin: 0 auto;
  }
  .auth-signature {
    display: flex;
    justify-content: center;
    margin-top: 0;
  }
  .auth-signature img {
    width: min(220px, 56vw);
    height: auto;
  }
  .section--white .auth-copy .auth-signature {
    color: var(--light-fg);
  }
  .collections-header {
    max-width: 760px;
    margin-bottom: 3.5rem;
  }
  .collections-h2 {
    font-size: var(--text-h1);
    color: var(--fg);
  }
  .coll-grid {
    display: grid;
    border: 1px solid var(--border);
    background: var(--border);
    gap: 1px;
  }
  .coll-card {
    background: var(--surface);
    display: flex;
    flex-direction: column;
    transition: background 0.3s ease;
  }
  .coll-card:hover { background: var(--surface-lift); }
  .coll-card:hover .product-img { transform: scale(1.04); }
  .coll-body {
    padding: 2rem;
    flex: 1;
    display: flex;
    flex-direction: column;
  }
  .coll-title {
    font-family: var(--font-display);
    font-weight: 400;
    line-height: 1.1;
    font-size: var(--text-h3);
    letter-spacing: var(--tracking-normal);
    color: var(--fg);
    margin-bottom: 1.25rem;
  }
  .coll-desc {
    font-size: 14px;
    font-weight: 300;
    line-height: var(--leading-loose);
    color: var(--fg-sub);
    margin-bottom: 2rem;
    flex: 1;
    text-wrap: pretty;
  }
  .coll-body .link-arrow {
    font-size: 12px;
  }
  .quote-section {
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    text-align: center;
  }
  .quote-inner {
    max-width: 960px;
    margin: 0 auto;
  }
  .pull-quote {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 300;
    line-height: 1.25;
    letter-spacing: var(--tracking-normal);
    font-size: var(--text-h2);
    color: var(--fg);
    margin-bottom: 2rem;
    text-wrap: balance;
  }
  .quote-attr {
    font-family: var(--font-label);
    font-size: 10px;
    font-style: normal;
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    color: var(--accent-light);
  }
  .beads-editorial {
    display: grid;
    gap: 3rem;
    max-width: 840px;
    margin: 0 auto;
  }
  .beads-editorial-head { text-align: center; }
  .beads-editorial-head h2 {
    font-size: var(--text-h1);
    color: var(--fg);
  }
  .eyebrow.centered {
    justify-content: center;
  }
  .beads-editorial-copy {
    max-width: 600px;
    margin: 0 auto;
  }
  .personal-grid,
  .gift-grid {
    display: grid;
    gap: 3.5rem;
    align-items: center;
  }
  .personal-story-section {
    padding-bottom: 0;
    padding-top: 2.5rem;
  }
  .personal-story-section .personal-grid {
    align-items: center;
  }
  .personal-story-section .personal-copy {
    order: 1;
  }
  .personal-story-section .personal-img {
    order: 2;
    align-self: end;
  }
  .personal-story-section .personal-copy {
    max-width: 620px;
    margin-inline: auto;
  }
  .personal-story-section .personal-copy h2 {
    text-align: center;
  }
  .personal-story-section .personal-btns {
    justify-content: center;
  }
  .personal-copy h2,
  .gift-copy h2 {
    font-size: var(--text-h2);
    margin-bottom: 1.75rem;
  }
  .personal-copy p,
  .gift-copy p {
    margin-bottom: 2rem;
  }
  .personal-btns {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }
  .cta-strip {
    border-top: 1px solid var(--border);
  }
  .cta-flex {
    max-width: 960px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    text-align: center;
  }
  .cta-text h2 {
    font-size: var(--text-h2);
    color: var(--fg);
    margin-bottom: 1rem;
  }
  .cta-text p {
    font-size: 15px;
    font-weight: 300;
    line-height: var(--leading-loose);
    color: oklch(97% 0.008 75 / 0.68);
  }
  .section--white .auth-headline,
  .section--white .personal-copy h2,
  .section--white .gift-copy h2 {
    color: var(--light-fg);
  }
  .section--white .auth-copy p,
  .section--white .personal-copy p,
  .section--white .gift-copy p {
    color: var(--light-sub);
  }
  @media (min-width: 640px) {
    .coll-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }
  @media (min-width: 768px) {
    .auth-signature { justify-content: flex-end; }
  }
  @media (min-width: 1024px) {
    .trust-grid { grid-template-columns: repeat(4, 1fr); }
    .trust-item { border-bottom: none; }
    .trust-item:nth-child(2n) { border-right: 1px solid var(--light-border); }
    .trust-item:last-child { border-right: none; }
    .coll-grid { grid-template-columns: repeat(4, minmax(0, 1fr)); }
    .personal-grid { grid-template-columns: 1fr 1fr; }
    .personal-story-section .personal-img {
      order: 1;
    }
    .personal-story-section .personal-copy {
      order: 2;
    }
    .gift-grid { grid-template-columns: 0.95fr 1.05fr; }
  }
  @media (max-width: 767px) {
    #hero {
      min-height: 85vh;
      padding: 7rem 0 4rem;
    }
    .hero-content,
    .trust-grid { padding-inline: 1.5rem; }
    .trust-item {
      padding: 1.25rem;
      gap: 10px;
    }
    .coll-body { padding: 1.5rem; }
  }
  @media (prefers-reduced-motion: reduce) {
    .coll-card:hover .product-img {
      transform: none !important;
    }
  }
</style>
