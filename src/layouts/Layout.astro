---
import CartDrawer from '../components/CartDrawer.astro';
import SearchModal from '../components/SearchModal.astro';
import Footer from '../components/Footer.astro';
import '../styles/tailwind.css';
import desirePro from '../assets/fonts/desirepro.otf';
import foundersGrotesk from '../assets/fonts/Founders Grotesk Light.otf';
import favicon from '../assets/images/favicon-gold.png';

export interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const {
  title = 'Rosario Leonardi Murano Glass',
  description = 'One-of-a-kind Murano glass jewelry and beads with verified Venetian and European sourcing.',
  image = '/Rosario-Leonardi-Social-Share-Black-v2.png',
} = Astro.props;

const siteUrl = Astro.site ?? new URL('https://rosarioleonardi.shop');
const canonicalURL = new URL(Astro.url.pathname, siteUrl);
const ogImage = image.startsWith('http') ? image : new URL(image, siteUrl).href;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" href={favicon.src} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="preload" href={desirePro.src} as="font" type="font/otf" crossorigin />
    <link rel="preload" href={foundersGrotesk.src} as="font" type="font/otf" crossorigin />

    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:site_name" content="Rosario Leonardi Murano Glass" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1000" />
    <meta property="og:image:height" content="600" />
    <meta property="og:image:alt" content={title} />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <style is:global define:vars={{ desireProUrl: `url(${desirePro.src})`, foundersGroteskUrl: `url(${foundersGrotesk.src})` }}>
      @font-face {
        font-family: 'DesirePro';
        src: var(--desireProUrl) format('opentype');
        font-weight: normal;
        font-style: normal;
        font-display: swap;
      }
      @font-face {
        font-family: 'FoundersGrotesk';
        src: var(--foundersGroteskUrl) format('opentype');
        font-weight: 300;
        font-style: normal;
        font-display: swap;
      }
      :root {
        --bg: oklch(7% 0.010 255);
        --surface: oklch(12% 0.010 255);
        --surface-lift: oklch(17% 0.010 255);
        --fg: oklch(97% 0.008 75);
        --fg-sub: oklch(72% 0.008 75);
        --muted: oklch(42% 0.008 255);
        --border: oklch(20% 0.010 255);
        --border-lift: oklch(28% 0.010 255);
        --accent: oklch(64% 0.115 72);
        --accent-light: oklch(80% 0.08 78);
        --accent-deep: oklch(52% 0.10 68);
        --cobalt: oklch(22.5% 0.06 256);
        --cobalt-dark: oklch(16% 0.05 256);
        --light-bg: oklch(99% 0.003 240);
        --light-surface: oklch(96% 0.004 240);
        --light-fg: oklch(13% 0.010 255);
        --light-sub: oklch(48% 0.008 255);
        --light-border: oklch(88% 0.006 240);
        --font-display: 'DesirePro', Georgia, serif;
        --font-wordmark: 'DesirePro', Georgia, serif;
        --font-body: 'FoundersGrotesk', -apple-system, system-ui, sans-serif;
        --font-label: 'FoundersGrotesk', -apple-system, system-ui, sans-serif;
        --font-mono: var(--font-label);
        --text-display: clamp(64px, 9vw, 120px);
        --text-h1: clamp(44px, 6vw, 72px);
        --text-h2: clamp(32px, 4.5vw, 56px);
        --text-h3: clamp(22px, 2.8vw, 32px);
        --text-body: 16px;
        --text-small: 13px;
        --text-label: 11px;
        --leading-display: 0.98;
        --leading-heading: 1.05;
        --leading-body: 1.65;
        --leading-loose: 1.8;
        --tracking-normal: 0;
        --tracking-wide: 0.08em;
        --tracking-wider: 0.18em;
        --tracking-widest: 0.22em;
        --space-1: 0.25rem;
        --space-2: 0.5rem;
        --space-3: 0.75rem;
        --space-4: 1rem;
        --space-5: 1.5rem;
        --space-6: 2rem;
        --space-7: 3rem;
        --space-8: 4rem;
        --space-9: 6rem;
        --radius-sharp: 2px;
        --radius-sm: 4px;
        --radius-md: 8px;
        --radius-lg: 12px;
        --radius-pill: 999px;
        --hero-overlay:
          linear-gradient(to top, oklch(7% 0.010 255 / 1) 0%, oklch(7% 0.010 255 / 0.82) 28%, oklch(7% 0.010 255 / 0.45) 55%, oklch(7% 0.010 255 / 0.15) 80%, transparent 100%),
          radial-gradient(circle at 50% 72%, oklch(7% 0.010 255 / 0.36) 0%, oklch(7% 0.010 255 / 0.18) 0, transparent 64%);
      }
      [x-cloak] { display: none !important; }
      *, *::before, *::after { box-sizing: border-box; }
      html { scroll-behavior: smooth; }
      img { display: block; max-width: 100%; }
      a { color: inherit; text-decoration: none; }
      button { font: inherit; cursor: pointer; }
      body {
        background: var(--bg);
        color: var(--fg);
        font-family: var(--font-body);
        font-weight: 300;
        -webkit-font-smoothing: antialiased;
        line-height: 1.6;
      }
      :focus-visible {
        outline: 2px solid var(--accent);
        outline-offset: 3px;
        border-radius: var(--radius-sharp);
      }
      :focus:not(:focus-visible) { outline: none; }
      .font-display { font-family: var(--font-display); }
      .font-sans { font-family: var(--font-body); }
      .font-mono { font-family: var(--font-mono); }
      .eyebrow {
        display: flex;
        align-items: center;
        gap: var(--space-4);
        margin-bottom: var(--space-5);
      }
      .eyebrow-rule {
        display: block;
        width: 28px;
        height: 1px;
        background: var(--accent);
        flex-shrink: 0;
      }
      .eyebrow-text {
        font-family: var(--font-label);
        font-weight: 400;
        font-size: var(--text-label);
        letter-spacing: var(--tracking-widest);
        text-transform: uppercase;
        color: var(--accent);
      }
      .btn-primary,
      .btn-ghost,
      .link-arrow {
        display: inline-flex;
        align-items: center;
        font-family: var(--font-label);
        font-size: 10px;
        letter-spacing: var(--tracking-wider);
        text-transform: uppercase;
      }
      .btn-primary {
        padding: var(--space-3) 1.75rem;
        background: var(--fg);
        color: var(--bg);
        border-radius: var(--radius-sharp);
        transition: background 0.3s cubic-bezier(0.16,1,0.3,1);
      }
      .btn-primary:hover { background: var(--accent-light); }
      .btn-primary:active { background: var(--accent-deep); }
      .btn-primary--accent {
        background: var(--accent);
        color: var(--bg);
      }
      .btn-primary--accent:hover { background: var(--accent-deep); }
      .btn-ghost {
        padding: var(--space-3) 1.75rem;
        color: var(--fg);
        border: 1px solid var(--border-lift);
        border-radius: var(--radius-sharp);
        transition: border-color 0.3s, color 0.3s, background 0.3s;
      }
      .btn-ghost:hover { border-color: var(--accent); color: var(--accent); }
      .btn-ghost:active { background: oklch(100% 0 0 / 0.04); }
      .link-arrow {
        gap: 8px;
        color: var(--accent);
        transition: gap 0.3s cubic-bezier(0.16,1,0.3,1), color 0.3s, opacity 0.3s;
      }
      .link-arrow:hover { gap: 14px; }
      .link-arrow:active { opacity: 0.65; }
      .section { padding: 6rem 2.5rem; }
      .section--surface { background: var(--surface); }
      .section--lift { background: var(--surface-lift); }
      .section--white { background: var(--light-bg); color: var(--light-fg); }
      .inner { max-width: 1180px; margin: 0 auto; }
      .inner--wide { max-width: 1440px; margin: 0 auto; }
      .product-img {
        display: block;
        width: 100%;
        object-fit: cover;
      }
      .section--white .eyebrow-text { color: var(--cobalt); }
      .section--white .eyebrow-rule { background: var(--cobalt); }
      .section--white .link-arrow { color: var(--cobalt); }
      .section--white .link-arrow:hover { color: var(--cobalt-dark); }
      .section--white .btn-primary {
        background: var(--light-fg);
        color: var(--light-bg);
      }
      .section--white .btn-primary:hover { background: var(--cobalt); }
      .section--white .btn-ghost {
        border-color: oklch(60% 0.008 255);
        color: var(--light-fg);
      }
      .section--white .btn-ghost:hover { border-color: var(--cobalt); color: var(--cobalt); }

      /* Scroll reveal */
      .reveal {
        opacity: 0;
        transform: translateY(28px);
        transition: opacity 0.85s cubic-bezier(0.16,1,0.3,1), transform 0.85s cubic-bezier(0.16,1,0.3,1);
      }
      .reveal-left {
        opacity: 0;
        transform: translateX(-32px);
        transition: opacity 0.9s cubic-bezier(0.16,1,0.3,1), transform 0.9s cubic-bezier(0.16,1,0.3,1);
      }
      .reveal-right {
        opacity: 0;
        transform: translateX(32px);
        transition: opacity 0.9s cubic-bezier(0.16,1,0.3,1), transform 0.9s cubic-bezier(0.16,1,0.3,1);
      }
      .reveal.visible,
      .reveal.revealed,
      .reveal-left.visible,
      .reveal-right.visible {
        opacity: 1;
        transform: none;
      }
      .reveal-delay-1 { transition-delay: 0.1s; }
      .reveal-delay-2 { transition-delay: 0.22s; }
      .reveal-delay-3 { transition-delay: 0.34s; }

      /* Link arrow gap animation */
      .link-arrow {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        transition: gap 0.2s;
      }
      .link-arrow:hover { gap: 14px; }
      @media (max-width: 767px) {
        .section { padding: 3.5rem 1.5rem; }
      }
      @media (prefers-reduced-motion: reduce) {
        *, *::before, *::after {
          animation-duration: 0.01ms !important;
          animation-iteration-count: 1 !important;
          transition-duration: 0.01ms !important;
        }
        html { scroll-behavior: auto; }
        .reveal { opacity: 1 !important; transform: none !important; }
      }

      /* Trust bar marquee */
      @keyframes trustScroll {
        0%   { transform: translateX(0); }
        100% { transform: translateX(-50%); }
      }

      /* Hero scroll nudge */
      @keyframes scrollPulse {
        0%, 100% { opacity: 0.3; transform: scaleY(1); }
        50%       { opacity: 0.8; transform: scaleY(0.6) translateY(12px); }
      }
    </style>
  </head>

  <body class="font-sans antialiased overflow-x-hidden">
    <CartDrawer />
    <SearchModal />
    <slot />
    <Footer />

    <script>
      // Scroll reveal via IntersectionObserver
      const revealObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('visible');
              entry.target.classList.add('revealed');
              revealObserver.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.1, rootMargin: '0px 0px -48px 0px' }
      );

      document.addEventListener('DOMContentLoaded', () => {
        document.querySelectorAll('.reveal, .reveal-left, .reveal-right').forEach((el) => {
          revealObserver.observe(el);
        });
      });
    </script>
  </body>
</html>
