---
const shopLinks = [
  { label: 'All Products', href: '/shop' },
  { label: 'Featured', href: '/#products' },
  { label: 'Cart', href: '#cart' },
];

const learnLinks = [
  { label: 'About', href: '/about' },
  { label: 'Contact', href: '/contact' },
  { label: 'Privacy', href: '/privacy' },
  { label: 'Terms', href: '/terms' },
];

const shopDomain = import.meta.env.PUBLIC_SHOPIFY_STORE_DOMAIN || 'your-store.myshopify.com';
const accountHref = `https://${shopDomain}/account/login`;
---

<footer class="bg-ink">

  <!-- Gold accent line -->
  <div class="h-px bg-gold w-full"></div>

  <div class="max-w-[1440px] mx-auto px-10 pt-20 pb-11">

    <!-- Main grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-[1.3fr_1fr_1fr_1.4fr] gap-12 lg:gap-14 mb-16 text-center sm:text-left">

      <!-- Brand: large standalone logo -->
      <div class="flex flex-col items-center sm:items-start">
        <a href="/" class="block mb-7 shrink-0">
          <span class="flex h-24 w-24 items-center justify-center rounded-full border border-white/15 bg-white/5 font-mono text-xl tracking-[0.18em] text-white lg:h-[160px] lg:w-[160px]">SS</span>
        </a>
        <p class="max-w-[260px] font-sans text-[13px] font-light leading-[1.8] text-white/65">
          A reusable Astro storefront wired for Shopify Storefront API products, cart, checkout, search, and discount links.
        </p>
      </div>

      <!-- Shop -->
      <div>
        <h4 class="font-mono text-[9px] tracking-[0.22em] uppercase mb-6 text-white/70">Shop</h4>
        <ul class="space-y-3.5">
          {shopLinks.map(({ label, href }) => (
            <li>
              <a
                href={href}
                @click={href === '#cart' ? '$store.cart.open()' : undefined}
                class="font-sans font-light text-[13px] text-white/75 transition-colors duration-200"
                onmouseover="this.style.color='oklch(80% 0.08 78)'"
                onmouseout="this.style.color='rgba(255,255,255,0.75)'"
              >{label}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Learn -->
      <div>
        <h4 class="font-mono text-[9px] tracking-[0.22em] uppercase mb-6 text-white/70">Learn</h4>
        <ul class="space-y-3.5">
          {learnLinks.map(({ label, href }) => (
            <li>
              <a
                href={href}
                class="font-sans font-light text-[13px] text-white/75 transition-colors duration-200"
                onmouseover="this.style.color='oklch(80% 0.08 78)'"
                onmouseout="this.style.color='rgba(255,255,255,0.75)'"
              >{label}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Connect -->
      <div>
        <h4 class="font-mono text-[9px] tracking-[0.22em] uppercase mb-6 text-white/70">Configure</h4>
        <p class="font-sans font-light text-[13px] leading-[1.8] text-white/65">
          Set Shopify domains and Storefront API tokens in <code class="font-mono text-white/80">.env</code>, then customize the starter content and styles for each new store.
        </p>
      </div>
    </div>

    <!-- Bottom bar -->
    <div
      class="flex flex-col items-center sm:flex-row sm:items-center justify-between gap-4 pt-8 text-center sm:text-left"
      style="border-top: 1px solid rgba(255,255,255,0.06);"
    >
      <p class="font-mono text-[9px] tracking-[0.15em] uppercase text-white/60">
        © {new Date().getFullYear()} Shopify Starter ·
        {[
          ['Privacy  · ', '/privacy'],
          ['Terms  · ', '/terms'],
          ['Returns', '/returns'],
        ].map(([label, href]) => (
            <a
                href={href}
                class="font-mono text-[9px] tracking-[0.15em] uppercase text-white/60 transition-colors duration-200"
                onmouseover="this.style.color='rgba(255,255,255,0.5)'"
                onmouseout="this.style.color='rgba(255,255,255,0.6)'"
            >{label}</a>
        ))}
      </p>
      <div class="flex flex-wrap items-center justify-center sm:justify-end gap-x-6 gap-y-3">
        <a
          href={accountHref}
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-1.5 font-mono text-[9px] tracking-[0.18em] uppercase text-white/40 transition-colors duration-200 hover:text-white/70"
        >
          <svg class="w-2.5 h-2.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
            <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
          </svg>
          Shopify Account
        </a>
      </div>
    </div>

  </div>
</footer>
