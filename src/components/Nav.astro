---
import rosarioIconGold from '../assets/images/rosario-icon-gold.png';

export interface Props {
  position?: 'fixed' | 'sticky';
  homeInitialMinimal?: boolean;
}

const { homeInitialMinimal = false } = Astro.props;
const scrollThreshold = homeInitialMinimal ? 0 : 60;
const accountHref = `https://${import.meta.env.PUBLIC_SHOPIFY_STORE_DOMAIN || 'your-store.myshopify.com'}/account`;
const navLinks = [
  ['Shop', '/shop'],
  ['About', '/about'],
  ['FAQ', '/faq'],
  ['Contact', '/contact'],
];
---

<header
  id="site-nav"
  x-data={`{ open: false, scrolled: false, pastMarquee: false, announcementProgress: 0, navProgress: 0, homeInitialMinimal: ${homeInitialMinimal ? 'true' : 'false'} }`}
  x-init={`
    const hero = document.getElementById('hero');
    const update = () => {
      const y = window.scrollY;
      scrolled = y > ${scrollThreshold} || !hero;
      announcementProgress = hero ? Math.min(y, 44) : 44;
      navProgress = hero ? Math.min(y / 44, 1) : (scrolled ? 1 : 0);
      pastMarquee = announcementProgress >= 44;
    };
    window.addEventListener('scroll', update, { passive: true });
    update();
  `}
  :class="{ 'scrolled': scrolled }"
  class:list={['site-nav', { 'home-initial-minimal': homeInitialMinimal }]}
  role="banner"
>
  {homeInitialMinimal && (
    <div
      class="announcement bg-brand-dark-blue"
      :class="pastMarquee ? 'hidden' : ''"
      :style="`max-height: ${44 - announcementProgress}px; opacity: ${1 - (announcementProgress / 44)}; transform: translateY(${-announcementProgress}px);`"
    >
      <a href="/shop" class="text-white">Real Moretti Murano. One-of-a-kind pieces, never restocked. →</a>
    </div>
  )}

  <nav class="nav-bar" aria-label="Main navigation" :style="`height: ${72 - (navProgress * 16)}px;`">
    <a href="/" class="nav-logo" aria-label="Rosario Leonardi, Home">
      <img src={rosarioIconGold.src} alt="" aria-hidden="true" class="nav-logo-img" />
      <span class="nav-wordmark">Rosario Leonardi</span>
    </a>

    <div class="nav-right">
      <ul
        class="nav-links-right"
        role="list"
        :style="homeInitialMinimal ? 'max-width: ' + (navProgress * 280) + 'px; opacity: ' + navProgress + '; gap: ' + (navProgress * 1.75) + 'rem;' : ''"
      >
        {navLinks.map(([label, href]) => (
          <li><a href={href} class="nav-link">{label}</a></li>
        ))}
      </ul>

      <span
        class="nav-group-sep"
        aria-hidden="true"
        :style="homeInitialMinimal ? 'max-width: ' + navProgress + 'px; opacity: ' + navProgress + ';' : ''"
      ></span>

      <div class="nav-icons">
        <button
          type="button"
          class="nav-icon"
          aria-label="Search"
          @click="$store.search.isOpen ? $store.search.close() : $store.search.open()"
        >
          <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5" aria-hidden="true">
            <circle cx="11" cy="11" r="8" />
            <path stroke-linecap="round" d="m21 21-4.35-4.35" />
          </svg>
        </button>
        <a href={accountHref} class="nav-icon" aria-label="Account">
          <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
            <circle cx="12" cy="7" r="4" />
          </svg>
        </a>
        <button
          type="button"
          class="nav-icon"
          aria-label="Cart"
          @click="$store.cart.open()"
        >
          <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z" />
            <line x1="3" y1="6" x2="21" y2="6" />
            <path stroke-linecap="round" d="M16 10a4 4 0 0 1-8 0" />
          </svg>
          <span x-show="$store.cart.totalQuantity > 0" x-text="$store.cart.totalQuantity" class="cart-badge"></span>
        </button>
        <span class="nav-divider" aria-hidden="true"></span>
      </div>

      <a href="/shop" class="btn-primary nav-cta">Shop Now</a>

      <button
        type="button"
        class="hamburger"
        :class="open ? 'open' : ''"
        aria-label="Open menu"
        :aria-expanded="open ? 'true' : 'false'"
        @click="open = !open; document.body.style.overflow = open ? 'hidden' : ''"
      >
        <span></span>
        <span></span>
      </button>
    </div>
  </nav>

  <nav
    id="mobile-drawer"
    aria-label="Mobile navigation"
    :aria-hidden="open ? 'false' : 'true'"
    :class="open ? 'open' : ''"
  >
    {navLinks.map(([label, href]) => (
      <a href={href} class="mobile-link" @click="open = false; document.body.style.overflow = ''">{label}</a>
    ))}
    <div class="mobile-actions">
      <a href={accountHref} class="mobile-account">Account</a>
      <a href="/shop" class="mobile-shop">Shop Now</a>
    </div>
  </nav>
</header>

<style>
  .site-nav {
    position: fixed;
    inset: 0 0 auto 0;
    z-index: 100;
    transition: background 0.45s cubic-bezier(0.16,1,0.3,1), backdrop-filter 0.45s cubic-bezier(0.16,1,0.3,1), border-color 0.45s ease;
  }
  .site-nav.scrolled,
  .site-nav:not(.home-initial-minimal) {
    background: oklch(from var(--cobalt) l c h / 0.96);
    backdrop-filter: blur(20px);
    border-bottom: 1px solid var(--border);
    box-shadow: 0 8px 16px rgba(0,0,0,0.08), 0 24px 48px rgba(0,0,0,0.10);
  }
  .announcement {
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    height: 44px;
    padding: 0 24px;
    border-bottom: 1px solid var(--border);
    overflow: hidden;
    max-height: 44px;
    opacity: 1;
    transform: translateY(0);
    will-change: max-height, opacity, transform;
  }
  .announcement.hidden {
    border-bottom-color: transparent;
  }
  .announcement a {
    font-family: var(--font-label);
    font-size: 10px;
    line-height: 1;
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
  }
  .nav-bar {
    max-width: 1440px;
    margin: 0 auto;
    padding: 0 2.5rem;
    display: flex;
    align-items: center;
    height: 72px;
    transition: height 0.45s cubic-bezier(0.16,1,0.3,1);
    will-change: height;
  }
  .nav-logo {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    flex-shrink: 0;
    z-index: 1;
  }
  .nav-logo-img {
    width: 28px;
    height: 34px;
    object-fit: contain;
    flex-shrink: 0;
    transform: translateY(2px);
  }
  .nav-wordmark {
    font-family: var(--font-wordmark);
    font-size: 28px;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--fg);
    line-height: 1;
  }
  .nav-right {
    margin-left: auto;
    display: flex;
    align-items: center;
    gap: var(--space-5);
    z-index: 1;
    transition: gap 0.45s cubic-bezier(0.16,1,0.3,1);
  }
  .nav-links-right {
    display: flex;
    align-items: center;
    gap: 1.75rem;
    list-style: none;
    max-width: 280px;
    opacity: 1;
    overflow: hidden;
    visibility: visible;
  }
  .nav-link {
    font-family: var(--font-label);
    font-size: 10px;
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: var(--fg-sub);
    position: relative;
    padding-bottom: 2px;
    transition: color 0.2s;
  }
  .nav-link:hover { color: var(--fg); }
  .nav-link::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 0;
    height: 1px;
    background: var(--accent);
    transition: width 0.3s cubic-bezier(0.16,1,0.3,1);
  }
  .nav-link:hover::after { width: 100%; }
  .home-initial-minimal:not(.scrolled) .nav-links-right,
  .home-initial-minimal:not(.scrolled) .nav-group-sep {
    width: 0;
    max-width: 0;
    gap: 0;
    opacity: 0;
    overflow: hidden;
    pointer-events: none;
    visibility: hidden;
  }
  .home-initial-minimal .nav-links-right {
    transition:
      opacity 0.4s cubic-bezier(0.16,1,0.3,1),
      max-width 0.48s cubic-bezier(0.16,1,0.3,1),
      gap 0.48s cubic-bezier(0.16,1,0.3,1),
      visibility 0.4s ease;
  }
  .home-initial-minimal .nav-group-sep {
    max-width: 1px;
    transition:
      opacity 0.4s cubic-bezier(0.16,1,0.3,1),
      max-width 0.48s cubic-bezier(0.16,1,0.3,1),
      visibility 0.4s ease;
  }
  .nav-group-sep,
  .nav-divider {
    width: 1px;
    height: 18px;
    background: oklch(100% 0 0 / 0.18);
    flex-shrink: 0;
  }
  .nav-icons {
    display: flex;
    align-items: center;
    gap: 1.25rem;
  }
  .nav-icon {
    display: flex;
    align-items: center;
    color: var(--fg-sub);
    transition: color 0.25s ease, transform 0.45s cubic-bezier(0.16,1,0.3,1);
    position: relative;
  }
  .nav-icon:hover { color: var(--fg); }
  .nav-icon svg { width: 17px; height: 17px; }
  .cart-badge {
    position: absolute;
    top: -7px;
    right: -7px;
    width: 16px;
    height: 16px;
    border-radius: var(--radius-pill);
    background: var(--accent);
    color: var(--bg);
    font-family: var(--font-label);
    font-size: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    line-height: 1;
  }
  .nav-cta {
    padding: var(--space-3) 1.5rem;
    transition:
      background 0.35s cubic-bezier(0.16,1,0.3,1),
      border-color 0.35s cubic-bezier(0.16,1,0.3,1),
      color 0.35s cubic-bezier(0.16,1,0.3,1);
  }
  .site-nav:not(.scrolled) .nav-cta {
    background: oklch(100% 0 0 / 0.08);
    color: var(--fg);
    border: 1px solid oklch(100% 0 0 / 0.22);
  }
  .home-initial-minimal:not(.scrolled) .nav-cta {
    background: var(--accent);
    border-color: var(--accent);
    color: var(--bg);
  }
  .site-nav:not(.scrolled) .nav-cta:hover {
    background: var(--accent);
    border-color: var(--accent);
    color: var(--bg);
  }
  .hamburger {
    display: none;
    flex-direction: column;
    gap: 5px;
    padding: 4px;
  }
  .hamburger span {
    display: block;
    height: 1px;
    background: var(--fg);
    transition: transform 0.25s, width 0.25s;
  }
  .hamburger span:nth-child(1) { width: 22px; }
  .hamburger span:nth-child(2) { width: 14px; align-self: flex-end; }
  .hamburger.open span:nth-child(1) { transform: rotate(45deg) translate(4px, 4px); width: 20px; }
  .hamburger.open span:nth-child(2) { transform: rotate(-45deg) translate(3px, -4px); width: 20px; }
  #mobile-drawer {
    position: fixed;
    inset: 0;
    background: var(--bg);
    z-index: 99;
    padding: 96px 2rem 2.5rem;
    display: flex;
    flex-direction: column;
    opacity: 0;
    pointer-events: none;
    transform: translateY(-8px);
    transition: opacity 0.25s ease, transform 0.25s ease;
    overflow-y: auto;
  }
  #mobile-drawer.open {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0);
  }
  .mobile-link {
    display: block;
    padding: 1.25rem 0;
    font-family: var(--font-label);
    font-size: 11px;
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    color: var(--fg-sub);
    border-bottom: 1px solid var(--border);
  }
  .mobile-actions {
    margin-top: 1.5rem;
    display: flex;
    gap: var(--space-3);
  }
  .mobile-actions a {
    flex: 1;
    text-align: center;
    padding: 12px;
    font-family: var(--font-label);
    font-size: 10px;
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
  }
  .mobile-account { border: 1px solid var(--border-lift); color: var(--fg-sub); }
  .mobile-shop { background: var(--fg); color: var(--bg); }
  @media (max-width: 1023px) {
    .nav-wordmark,
    .nav-links-right,
    .nav-group-sep,
    .nav-divider,
    .nav-cta { display: none; }
    .hamburger { display: flex; }
    .nav-bar { padding: 0 1.5rem; }
  }
</style>
