---
import PolicyPage from '../components/PolicyPage.astro';

const sections = [
  {
    title: 'Use of this site',
    paragraphs: [
      'By using this website, you agree to follow these terms and any additional conditions posted on the site. If you do not agree, please do not use the site.',
      'We may update, suspend, or discontinue any part of the site at any time without notice.',
    ],
  },
  {
    title: 'Products and orders',
    paragraphs: [
      'Product descriptions, pricing, and availability are subject to change without notice. We do our best to keep information accurate, but we cannot guarantee every detail is always current.',
      'Orders are subject to acceptance and availability. We may refuse or cancel an order if there is an error, suspected fraud, or a product availability issue.',
    ],
  },
  {
    title: 'Product guidance',
    paragraphs: [
      'Content on this site is for general informational purposes only. Replace this section with guidance appropriate to the products sold by the target store.',
      'Product use, safety, sizing, compatibility, and care information should be reviewed against the target store catalog before launch.',
    ],
  },
  {
    title: 'Intellectual property',
    paragraphs: [
      'All site content, including text, images, logos, and product copy, belongs to the storefront owner or its licensors and may not be reused without permission.',
    ],
  },
  {
    title: 'Limitation of liability',
    paragraphs: [
      'To the fullest extent permitted by law, the storefront owner is not liable for indirect, incidental, or consequential damages arising from use of the site or products.',
    ],
  },
];
---

<PolicyPage
  title="Terms of Service"
  description="Starter terms for site use and purchases."
  eyebrow="Terms of Service"
  intro="These terms set expectations for using the site, placing orders, and reviewing product information."
  updatedLabel="Effective date: June 25, 2026"
  sections={sections}
/>
