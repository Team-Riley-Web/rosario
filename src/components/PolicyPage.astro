---
import Layout from '../layouts/Layout.astro';
import Nav from './Nav.astro';
import heroImage from '../assets/images/beader-header-1.png';

export interface PolicySection {
  title: string;
  paragraphs: string[];
  bullets?: string[];
}

export interface Props {
  title: string;
  description: string;
  eyebrow: string;
  intro: string;
  updatedLabel: string;
  sections: PolicySection[];
}

const { title, description, eyebrow, intro, updatedLabel, sections } = Astro.props as Props;
---

<Layout title={title} description={description}>
  <Nav />

  <main>
    <section class="bg-ink pt-[160px] pb-[84px] relative overflow-hidden">
      <img
        src={heroImage.src}
        alt=""
        class="absolute inset-0 h-full w-full object-cover object-[20%_center] sm:object-center"
        aria-hidden="true"
      />
      <div class="absolute inset-0 bg-ink/75" aria-hidden="true"></div>
      <div class="relative max-w-[1440px] mx-auto px-6 sm:px-10">
        <div class="max-w-[760px] mx-auto text-center">
          <div class="flex items-center justify-center gap-4 mb-8">
            <div class="h-px bg-gold w-6"></div>
            <span class="font-label text-[10px] tracking-[var(--tracking-widest)] uppercase text-gold">{eyebrow}</span>
            <div class="h-px bg-gold w-6"></div>
          </div>
          <h1 class="font-display font-light text-white leading-[var(--leading-heading)] tracking-normal mb-6 text-[length:var(--text-h1)]">
            {title}
          </h1>
          <p class="font-sans font-light text-[16px] leading-[var(--leading-loose)] max-w-[620px] mx-auto text-white/60">
            {intro}
          </p>
          <p class="mt-8 font-label text-[10px] tracking-[var(--tracking-wider)] uppercase text-white/45">
            {updatedLabel}
          </p>
        </div>
      </div>
      <div class="absolute bottom-0 inset-x-0 h-px bg-white/5"></div>
    </section>

    <section class="bg-white py-24">
      <div class="max-w-[1440px] mx-auto px-6 sm:px-10">
        <div class="max-w-[920px] mx-auto">
          <div class="space-y-14">
            {sections.map((section) => (
              <article class="reveal">
                <div class="flex items-center gap-4 mb-5">
                  <div class="h-px bg-gold w-6"></div>
                  <h2 class="font-display text-ink font-normal leading-[var(--leading-heading)] tracking-normal text-[length:var(--text-h3)]">
                    {section.title}
                  </h2>
                </div>
                <div class="space-y-5">
                  {section.paragraphs.map((paragraph) => (
                    <p class="font-sans font-light text-[15px] leading-[1.85] text-ink-soft">
                      {paragraph}
                    </p>
                  ))}
                </div>
                {section.bullets && (
                  <ul class="mt-6 grid gap-3">
                    {section.bullets.map((bullet) => (
                      <li class="flex items-start gap-3 font-sans font-light text-[15px] leading-[1.75] text-ink-soft">
                        <span class="mt-2 h-px w-5 bg-gold shrink-0"></span>
                        <span>{bullet}</span>
                      </li>
                    ))}
                  </ul>
                )}
              </article>
            ))}
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>
