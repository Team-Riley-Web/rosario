---
import type { ShopifyProduct } from '../lib/shopify';
import { formatPrice } from '../lib/shopify';

export interface Props {
  product: ShopifyProduct;
}

const { product } = Astro.props;
const image = product.images.edges[0]?.node;
const hoverImage = product.images.edges[1]?.node;
const variant = product.variants.edges[0]?.node;
const price = formatPrice(product.priceRange.minVariantPrice.amount);
const productPageUrl = `/products/${product.handle}`;
---

<article
  x-data="{ adding: false, added: false }"
  class="prod-card"
  role="listitem"
>
  <a href={productPageUrl} class="prod-card-img" aria-label={product.title}>
    {image ? (
      <>
        <img
          class="product-img product-img--primary"
          src={image.url}
          alt={image.altText ?? product.title}
          loading="lazy"
        />
        {hoverImage && (
          <img
            class="product-img product-img--hover"
            src={hoverImage.url}
            alt=""
            loading="lazy"
            aria-hidden="true"
          />
        )}
      </>
    ) : (
      <div class="product-img product-img--empty">
        <span>Rosario Leonardi</span>
      </div>
    )}
    {!product.availableForSale && <span class="prod-badge">Sold Out</span>}
  </a>

  <div class="prod-card-body">
    <a href={productPageUrl}>
      <h3 class="prod-card-name">{product.title}</h3>
    </a>
    <div class="prod-card-price">{price}</div>
    <p class="prod-card-sub">{product.description || 'One-of-a-kind Murano glass piece from Rosario Leonardi.'}</p>

    {variant ? (
      <button
        type="button"
        @click={`if (!adding && !added) {
          adding = true;
          await $store.cart.addItem('${variant.id}');
          adding = false;
          added = true;
          setTimeout(() => { added = false; }, 1800);
        }`}
        class="link-arrow prod-card-action"
        disabled={!product.availableForSale || undefined}
      >
        <span x-show="!adding && !added">{product.availableForSale ? 'Add to Cart' : 'Sold Out'}</span>
        <span x-show="adding">Adding...</span>
        <span x-show="added">Added</span>
        <span aria-hidden="true">→</span>
      </button>
    ) : (
      <a href={productPageUrl} class="link-arrow prod-card-action">View Product <span aria-hidden="true">→</span></a>
    )}
  </div>
</article>

<style>
  .prod-card {
    width: 100%;
    background: white;
    display: flex;
    flex-direction: column;
    transition: background 0.3s ease;
    color: var(--light-fg);
  }
  .prod-card:hover { background: var(--light-surface); }
  :global(.products-section--featured) .prod-card {
    background: var(--surface);
    color: var(--fg);
  }
  :global(.products-section--featured) .prod-card:hover {
    background: var(--surface-lift);
  }
  :global(.products-section--featured) .prod-card-img {
    background: var(--surface-lift);
  }
  :global(.products-section--featured) .prod-card-name {
    color: var(--fg);
  }
  :global(.products-section--featured) .prod-card-price,
  :global(.products-section--featured) .prod-card-sub {
    color: var(--fg-sub);
  }
  .prod-card-img {
    position: relative;
    display: block;
    overflow: hidden;
    background: var(--light-surface);
  }
  .prod-card-img .product-img {
    aspect-ratio: 3 / 4;
    width: 100%;
    object-fit: cover;
    transition:
      opacity 0.85s cubic-bezier(0.16,1,0.3,1),
      transform 1.15s cubic-bezier(0.16,1,0.3,1);
    will-change: opacity, transform;
  }
  .product-img--hover {
    position: absolute;
    inset: 0;
    height: 100%;
    opacity: 0;
  }
  .prod-card:hover .prod-card-img .product-img { transform: scale(1.025); }
  .prod-card:hover .product-img--hover { opacity: 1; }
  .prod-card:hover .product-img--primary:has(+ .product-img--hover) { opacity: 0.18; }
  .product-img--empty {
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--light-sub);
    font-family: var(--font-display);
    font-size: 28px;
  }
  .prod-badge {
    position: absolute;
    top: 14px;
    right: 14px;
    background: var(--bg);
    color: var(--fg);
    font-family: var(--font-label);
    font-size: var(--text-label);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    padding: var(--space-2) var(--space-3);
    border-radius: var(--radius-sm);
  }
  .prod-card-body {
    padding: var(--space-5);
    flex: 1;
    display: flex;
    flex-direction: column;
  }
  .prod-card-name {
    font-family: var(--font-display);
    font-weight: 400;
    line-height: var(--leading-heading);
    font-size: var(--text-h3);
    letter-spacing: var(--tracking-normal);
    color: var(--light-fg);
    margin-bottom: 0.5rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .prod-card-price {
    font-family: var(--font-label);
    font-size: 11px;
    letter-spacing: var(--tracking-wide);
    color: var(--light-sub);
    margin-bottom: 1.25rem;
    font-variant-numeric: tabular-nums;
  }
  .prod-card-sub {
    font-size: 12px;
    font-weight: 300;
    color: var(--light-sub);
    margin-bottom: 0;
    min-height: calc(12px * var(--leading-body) * 3);
    line-height: var(--leading-body);
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .prod-card-action {
    align-self: flex-start;
    margin-top: 20px;
    border: 0;
    background: transparent;
    padding: 0;
  }
  .prod-card-action:disabled {
    color: var(--light-sub);
    cursor: not-allowed;
  }
</style>
