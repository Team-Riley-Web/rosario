---
import Layout from '../../../layouts/Layout.astro';
import Nav from '../../../components/Nav.astro';
import ProductsSection from '../../../components/ProductsSection.astro';
import { getAllProducts } from '../../../lib/shopify';
import type { ShopifyProduct } from '../../../lib/shopify';

export async function getStaticPaths() {
  const productsPerPage = 16;
  const allProducts = await getAllProducts();
  const products = allProducts
    .map((product, bestSellingRank) => ({ ...product, bestSellingRank }))
    .sort((a, b) => a.title.localeCompare(b.title));
  const totalPages = Math.ceil(products.length / productsPerPage);

  return Array.from({ length: Math.max(0, totalPages - 1) }, (_, index) => {
    const currentPage = index + 2;

    return {
      params: { page: String(currentPage) },
      props: {
        products,
        currentPage,
        totalPages,
        totalProducts: products.length,
      },
    };
  });
}

const {
  products,
  currentPage,
  totalPages,
  totalProducts,
} = Astro.props as {
  products: ShopifyProduct[];
  currentPage: number;
  totalPages: number;
  totalProducts: number;
};
---

<Layout
  title={`Shop One-of-a-Kind Murano Glass — Page ${currentPage}`}
  description="Browse one-of-a-kind Murano glass jewelry, restored vintage Millefiori, freshwater pearls, and maker beads."
>
  <Nav />
  <main class="pt-[130px]">
    <ProductsSection
      variant="complete"
      products={products}
      pagination={{
        currentPage,
        totalPages,
        totalProducts,
      }}
    />
  </main>
</Layout>
