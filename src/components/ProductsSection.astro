---
import { getFeaturedProducts, getProducts } from '../lib/shopify';
import type { ShopifyProduct } from '../lib/shopify';
import ProductCard from './ProductCard.astro';
import { ArrowLeft, ArrowRight } from '@lucide/astro';

export interface Props {
  variant?: 'featured' | 'complete';
  products?: ShopifyProduct[];
  pagination?: {
    currentPage: number;
    totalPages: number;
    totalProducts: number;
  };
}

const { variant = 'featured', products: providedProducts, pagination } = Astro.props;
const isFeatured = variant === 'featured';
const products = providedProducts ?? (isFeatured ? await getFeaturedProducts() : await getProducts(16));
const hasProducts = products.length > 0;

const displayProducts = products;
const defaultFilter = 'all';
const defaultGroup = isFeatured ? 'all' : 'murano';
const primaryFilters = [
  { label: 'Murano', value: 'murano' },
  { label: 'Pearls', value: 'pearls' },
  { label: 'All', value: 'all' },
];
const subFilters = {
  murano: [
    { label: 'All Murano', value: 'all' },
    { label: 'Necklaces', value: 'necklaces' },
    { label: 'Earrings', value: 'earrings' },
    { label: 'Bracelets', value: 'bracelets' },
    { label: 'Rings', value: 'rings' },
    { label: 'Jewelry Sets', value: 'jewelry-sets' },
    { label: 'Signature Moretti', value: 'signature-moretti' },
    { label: 'Beads', value: 'beads-for-makers' },
  ],
  pearls: [
    { label: 'All Pearls', value: 'all' },
    { label: 'Necklaces', value: 'necklaces' },
    { label: 'Earrings', value: 'earrings' },
    { label: 'Bracelets', value: 'bracelets' },
    { label: 'Rings', value: 'rings' },
    { label: 'Jewelry Sets', value: 'jewelry-sets' },
  ],
  all: [
    { label: 'All Pieces', value: 'all' },
    { label: 'Necklaces', value: 'necklaces' },
    { label: 'Earrings', value: 'earrings' },
    { label: 'Bracelets', value: 'bracelets' },
    { label: 'Rings', value: 'rings' },
    { label: 'Jewelry Sets', value: 'jewelry-sets' },
    { label: 'Signature Moretti', value: 'signature-moretti' },
    { label: 'Beads', value: 'beads-for-makers' },
  ],
};
const legacyFilterValues = ['vintage-millefiori', 'uncirculated-vintage', 'freshwater-pearls'];
const allowedFilterValues = [...new Set([
  ...Object.values(subFilters).flat().map(({ value }) => value),
  ...legacyFilterValues,
])];
const heading = isFeatured ? 'Bestsellers' : 'Every Piece Is One of a Kind.';
const ctaHref = '/shop';
const ctaLabel = isFeatured ? 'Shop the Collection' : 'Reset View';

function getShopPageHref(page: number): string {
  return page === 1 ? '/shop' : `/shop/page/${page}`;
}

const categoryRules = [
  { value: 'necklaces', pattern: /\b(necklaces?|chokers?|pendants?|lariat)\b/ },
  { value: 'earrings', pattern: /\b(earrings?|studs?|hoops?|dangles?|drops?)\b/ },
  { value: 'bracelets', pattern: /\b(bracelets?|bangles?|cuffs?)\b/ },
  { value: 'rings', pattern: /\b(rings?)\b/ },
  { value: 'jewelry-sets', pattern: /\b(jewelry sets?|sets?)\b/ },
  { value: 'signature-moretti', pattern: /\b(moretti|signature)\b/ },
  { value: 'vintage-millefiori', pattern: /\b(vintage|millefiori|restored)\b/ },
  { value: 'uncirculated-vintage', pattern: /\b(uncirculated|european find|rare find)\b/ },
  { value: 'freshwater-pearls', pattern: /\b(freshwater|pearls?)\b/ },
  { value: 'beads-for-makers', pattern: /\b(beads?|lampwork|makers?|supplies|supply)\b/ },
];

const shopifyCategoryRules = [
  { value: 'necklaces', pattern: /^necklaces?$/ },
  { value: 'bracelets', pattern: /^bracelets?$/ },
  { value: 'rings', pattern: /^rings?$/ },
  { value: 'beads-for-makers', pattern: /^beads?$/ },
  { value: 'jewelry-sets', pattern: /^jewelry sets?$/ },
];

const groupRules = [
  { value: 'pearls', pattern: /\b(pearls?|freshwater)\b/ },
  { value: 'murano', pattern: /\b(murano|moretti|millefiori|venetian|venice|lampwork|glass|beads?|wedding cake)\b/ },
];

type MatchRule = { value: string; pattern: RegExp };

function compactText(values: Array<string | null | undefined>): string {
  return values.filter(Boolean).join(' ').toLowerCase();
}

function matchRuleValues(rules: MatchRule[], values: Array<string | null | undefined>): string[] {
  const text = compactText(values);
  if (!text) return [];

  return rules
    .filter(({ pattern }) => pattern.test(text))
    .map(({ value }) => value);
}

const productState = displayProducts.map((product, index) => {
  const rankedProduct = product as ShopifyProduct & { bestSellingRank?: number };
  const bestSellingRank = typeof rankedProduct.bestSellingRank === 'number'
    ? rankedProduct.bestSellingRank
    : index;
  const shopifyCategoryText = [
    product.category?.name,
  ];
  const merchandisingText = [
    ...product.tags,
    ...product.collections.edges.flatMap(({ node }) => [node.title, node.handle]),
  ];
  const descriptiveText = [
    product.title,
    product.handle,
    product.description,
  ];
  const productText = [
    ...shopifyCategoryText,
    ...merchandisingText,
    ...descriptiveText,
  ].filter(Boolean).join(' ').toLowerCase();
  let categoryMatches = matchRuleValues(shopifyCategoryRules, shopifyCategoryText);
  if (categoryMatches.length === 0) categoryMatches = matchRuleValues(categoryRules, merchandisingText);
  if (categoryMatches.length === 0) categoryMatches = matchRuleValues(categoryRules, descriptiveText);

  const categories = ['all', ...categoryMatches];
  const groups = ['all'];
  const groupMatches = [...new Set([
    ...matchRuleValues(groupRules, [...shopifyCategoryText, ...merchandisingText]),
    ...matchRuleValues(groupRules, descriptiveText),
  ])];
  groups.push(...groupMatches);
  if (groups.length === 1) groups.push('murano');

  return {
    id: product.id,
    title: product.title,
    searchText: productText,
    groups,
    categories,
    available: product.availableForSale,
    price: Number(product.priceRange.minVariantPrice.amount),
    bestSellingRank,
  };
});

const initialPage = pagination?.currentPage ?? 1;
const totalProductsLabel = pagination?.totalProducts ?? displayProducts.length;
const firstVisibleIndex = (initialPage - 1) * 16;
const lastVisibleIndex = firstVisibleIndex + 16;
---

<section
  class={`section products-section ${isFeatured ? 'products-section--featured' : 'products-section--complete section--white'}`}
  id="products"
>
  <div class="inner--wide">

    <!-- Header -->
    <div class="products-header reveal">
      <div>
        {!isFeatured && (
          <div class="eyebrow">
            <span class="eyebrow-rule" aria-hidden="true"></span>
            <span class="eyebrow-text">Current Collection</span>
          </div>
        )}
        <h2 class="products-heading">{heading}</h2>
        {!isFeatured && (
          <p class="products-intro">
            Real Moretti Murano. Real vintage history. Real materials for real makers. Nothing here is mass-produced, and nothing here will be exactly duplicated - browse knowing that if something speaks to you, it is worth not waiting.
          </p>
        )}
      </div>
      {isFeatured && (
        <a
          href={ctaHref}
          class="link-arrow products-cta"
        >
          {ctaLabel}
          <svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
          </svg>
        </a>
      )}
    </div>

    <!-- Filter tabs + grid (state) -->
    <div
      x-data={`{
        activeGroup: ${JSON.stringify(defaultGroup)},
        active: ${JSON.stringify(defaultFilter)},
        searchQuery: '',
        sortBy: 'alpha',
        page: ${initialPage},
        perPage: 16,
        products: ${JSON.stringify(productState)},
        init() {
          const params = new URLSearchParams(window.location.search);
          const group = params.get('group');
          const filter = params.get('filter');
          const search = params.get('search');
          if (${JSON.stringify(primaryFilters.map(({ value }) => value))}.includes(group ?? '')) {
            this.activeGroup = group;
          }
          if (${JSON.stringify(allowedFilterValues)}.includes(filter ?? '')) {
            this.active = filter;
            if (!group && filter === 'freshwater-pearls') this.activeGroup = 'pearls';
            if (!group && filter === 'beads-for-makers') this.activeGroup = 'murano';
          }
          if (search) {
            this.searchQuery = search.trim().toLowerCase();
            this.page = 1;
          }
        },
        currentSubFilters() {
          return ${JSON.stringify(subFilters)}[this.activeGroup] || ${JSON.stringify(subFilters.murano)};
        },
        setGroup(nextGroup) {
          this.activeGroup = nextGroup;
          this.active = 'all';
          this.page = 1;
        },
        reset() {
          this.activeGroup = ${JSON.stringify(defaultGroup)};
          this.active = ${JSON.stringify(defaultFilter)};
          this.searchQuery = '';
          this.sortBy = 'alpha';
          this.page = 1;
        },
        filteredProducts() {
          return this.products.filter((product) => {
            const matchesGroup = this.activeGroup === 'all' || product.groups.includes(this.activeGroup);
            const matchesFilter = this.active === 'all' || product.categories.includes(this.active);
            const matchesSearch = !this.searchQuery || product.searchText.includes(this.searchQuery);

            return matchesGroup && matchesFilter && matchesSearch;
          });
        },
        sortedProducts() {
          return [...this.filteredProducts()].sort((a, b) => {
            if (this.sortBy === 'best-selling') return a.bestSellingRank - b.bestSellingRank;
            if (this.sortBy === 'reverse-alpha') return b.title.localeCompare(a.title);
            if (this.sortBy === 'price-low-high') return a.price - b.price || a.title.localeCompare(b.title);
            if (this.sortBy === 'price-high-low') return b.price - a.price || a.title.localeCompare(b.title);
            return a.title.localeCompare(b.title);
          });
        },
        visibleProducts() {
          const currentTotalPages = this.totalPages();
          if (this.page > currentTotalPages) this.page = currentTotalPages;
          const start = (this.page - 1) * this.perPage;
          return this.sortedProducts().slice(start, start + this.perPage);
        },
        visibleIds() {
          return this.visibleProducts().map((product) => product.id);
        },
        productOrder(id) {
          return this.visibleIds().indexOf(id);
        },
        totalPages() {
          return Math.max(1, Math.ceil(this.filteredProducts().length / this.perPage));
        },
        paginationItems() {
          const total = this.totalPages();
          const windowSize = 5;
          const pages = [];

          if (total <= windowSize + 2) {
            return Array.from({ length: total }, (_, index) => ({
              type: 'page',
              page: index + 1,
              key: 'page-' + (index + 1),
            }));
          }

          const groupStart = Math.floor((this.page - 1) / windowSize) * windowSize + 1;
          const groupEnd = Math.min(groupStart + windowSize - 1, total);

          if (groupStart > 1) {
            pages.push({ type: 'page', page: 1, key: 'page-1' });
            if (groupStart > 2) pages.push({ type: 'ellipsis', key: 'ellipsis-start' });
          }

          for (let pageNumber = groupStart; pageNumber <= groupEnd; pageNumber += 1) {
            pages.push({ type: 'page', page: pageNumber, key: 'page-' + pageNumber });
          }

          if (groupEnd < total) {
            if (groupEnd < total - 1) pages.push({ type: 'ellipsis', key: 'ellipsis-end' });
            pages.push({ type: 'page', page: total, key: 'page-' + total });
          }

          return pages;
        },
        totalResults() {
          return this.filteredProducts().length;
        },
        setPage(nextPage) {
          const targetPage = Math.min(Math.max(nextPage, 1), this.totalPages());
          if (targetPage === this.page) return;

          this.page = targetPage;
          window.scrollTo({ top: 0, behavior: 'smooth' });
        }
      }`}
    >
      {/* Filter + sort — only for complete variant */}
      {!isFeatured && (
        <div class="products-controls">
          <div class="products-filter-stack">
            <div class="products-filters products-filters--primary" aria-label="Primary product filters">
              {primaryFilters.map(f => (
                <button
                  @click={`setGroup('${f.value}')`}
                  :class={`activeGroup === '${f.value}' ? 'is-active' : ''`}
                  class="filter-btn"
                >
                  {f.label}
                </button>
              ))}
            </div>

            <div class="products-filters" aria-label="Product subfilters">
              <template x-for="filter in currentSubFilters()" :key="filter.value">
                <button
                  @click="active = filter.value; page = 1"
                  :class="active === filter.value ? 'is-active' : ''"
                  class="filter-btn"
                  type="button"
                >
                  <span x-text="filter.label"></span>
                </button>
              </template>
            </div>
          </div>
          <div class="products-sort">
            <label for="product-sort">
              <span>Sort by</span>
              <span class="select-wrap">
                <select
                  id="product-sort"
                  name="sort"
                  x-model="sortBy"
                  @change="page = 1"
                  class="sort-select"
                >
                  <option value="alpha">Alphabetical</option>
                  <option value="best-selling">Best-selling</option>
                  <option value="reverse-alpha">Reverse alphabetical</option>
                  <option value="price-low-high">Price, low to high</option>
                  <option value="price-high-low">Price, high to low</option>
                </select>
                <svg
                  class="select-icon"
                  viewBox="0 0 20 20"
                  fill="currentColor"
                  aria-hidden="true"
                >
                  <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 0 1 1.06.02L10 11.17l3.71-3.94a.75.75 0 1 1 1.08 1.04l-4.25 4.5a.75.75 0 0 1-1.08 0l-4.25-4.5a.75.75 0 0 1 .02-1.06Z" clip-rule="evenodd" />
                </svg>
              </span>
            </label>

            <button
              type="button"
              @click="reset()"
              class="filter-btn"
            >
              Reset
            </button>
          </div>
        </div>
      )}

      {/* Products grid — 2px gap mosaic */}
      {hasProducts ? (
        <>
          {!isFeatured && (
            <div class="products-count">
              <p>Page <span x-text="page"></span> of <span x-text="totalPages()"></span></p>
              <p><span x-text="totalResults()"></span> of {totalProductsLabel} products</p>
            </div>
          )}

          <div x-cloak class={isFeatured ? 'prod-scroll-outer' : 'products-grid'} id={isFeatured ? 'bestsellers-scroll' : undefined} role={isFeatured ? 'region' : 'list'} aria-label={isFeatured ? 'Bestsellers - scroll to see more' : undefined}>
            <div class={isFeatured ? 'prod-scroll-grid' : 'products-grid-inner'}>
            {displayProducts.map((product, i) => {
              const isInitiallyVisible = i >= firstVisibleIndex && i < lastVisibleIndex;
              return (
                <div
                  x-show={`visibleIds().includes(${JSON.stringify(product.id)})`}
                  x-transition:enter="transition ease-out duration-200"
                  x-transition:enter-start="opacity-0 scale-95"
                  x-transition:enter-end="opacity-100 scale-100"
                  class="product-cell"
                  style={isInitiallyVisible ? undefined : 'display: none;'}
                  :style={`{ order: productOrder(${JSON.stringify(product.id)}) }`}
                >
                  <ProductCard product={product} />
                </div>
              );
            })}
            </div>
          </div>

          <p x-show="totalResults() === 0" class="products-empty">
            No products match the selected filters.
          </p>

          {!isFeatured && (
            <nav x-show="totalPages() > 1" class="products-pagination" aria-label="Product pagination">
              <a
                href={getShopPageHref(Math.max(initialPage - 1, 1))}
                @click.prevent="setPage(page - 1)"
                x-show="page > 1"
                class="page-link"
              >
                <ArrowLeft class="w-3.5 h-3.5" />
                Prev
              </a>

              <template x-for="paginationItem in paginationItems()" :key="paginationItem.key">
                <span>
                  <span
                    x-show="paginationItem.type === 'ellipsis'"
                    class="page-ellipsis"
                    aria-hidden="true"
                  >
                    ...
                  </span>
                  <a
                    x-show="paginationItem.type === 'page'"
                    :href="paginationItem.page === 1 ? '/shop' : `/shop/page/${paginationItem.page}`"
                    @click.prevent="setPage(paginationItem.page)"
                    :aria-current="paginationItem.page === page ? 'page' : undefined"
                    class="page-link page-number"
                    :class="paginationItem.page === page ? 'is-active' : ''"
                  >
                    <span x-text="paginationItem.page"></span>
                  </a>
                </span>
              </template>

              <a
                href={getShopPageHref(initialPage + 1)}
                @click.prevent="setPage(page + 1)"
                x-show="page < totalPages()"
                class="page-link page-arrow"
                aria-label="Next page"
              >
                <ArrowRight class="w-3.5 h-3.5" />
              </a>
            </nav>
          )}

          {pagination && pagination.totalPages > 1 && (
            <noscript>
              <nav class="mt-12 flex flex-wrap items-center justify-center gap-1" aria-label="Product pagination">
                {pagination.currentPage > 1 && (
                  <a
                    href={getShopPageHref(pagination.currentPage - 1)}
                    class="page-link"
                  >
                    Previous
                  </a>
                )}

                {Array.from({ length: pagination.totalPages }, (_, index) => index + 1).map(page => (
                  <a
                    href={getShopPageHref(page)}
                    aria-current={page === pagination.currentPage ? 'page' : undefined}
                  class={`page-link page-number ${page === pagination.currentPage ? 'is-active' : ''}`}
                  >
                    {page}
                  </a>
                ))}

                {pagination.currentPage < pagination.totalPages && (
                  <a
                    href={getShopPageHref(pagination.currentPage + 1)}
                    class="page-link"
                  >
                    Next
                  </a>
                )}
              </nav>
            </noscript>
          )}
        </>
      ) : (
        <p class="products-empty">
          Products are temporarily unavailable.
        </p>
      )}
    </div>
  </div>
</section>

<style>
  .products-section {
    background: var(--light-bg);
    color: var(--light-fg);
  }
  .products-section--featured {
    background: var(--bg);
    color: var(--fg);
  }
  .products-section--complete {
    padding-top: 9rem;
  }
  .products-header {
    max-width: 760px;
    margin-bottom: var(--space-8);
  }
  .products-section--featured .products-header {
    display: flex;
    align-items: end;
    justify-content: space-between;
    max-width: none;
    gap: 2rem;
  }
  .products-heading {
    font-family: var(--font-display);
    font-weight: 300;
    line-height: var(--leading-display);
    letter-spacing: var(--tracking-normal);
    font-size: var(--text-h1);
    color: var(--light-fg);
    text-wrap: balance;
  }
  .products-section--featured .products-heading {
    color: var(--fg);
  }
  .products-intro {
    margin-top: var(--space-4);
    max-width: 760px;
    font-size: 15px;
    font-weight: 300;
    line-height: var(--leading-loose);
    color: var(--light-sub);
  }
  .products-cta {
    flex-shrink: 0;
  }
  .products-section--featured .products-cta,
  .products-section--featured :global(.prod-card-action) {
    font-size: 12px;
  }
  .products-controls {
    margin-bottom: var(--space-7);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }
  .products-filter-stack {
    display: grid;
    gap: var(--space-3);
  }
  .products-filters,
  .products-sort {
    display: flex;
    flex-wrap: wrap;
    gap: 2px;
    align-items: center;
  }
  .products-filters--primary .filter-btn {
    border-color: oklch(72% 0.008 255);
  }
  .products-sort {
    gap: var(--space-3);
    justify-content: flex-end;
    margin-left: auto;
  }
  .products-sort label {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }
  .products-sort label > span:first-child,
  .products-count,
  .filter-btn,
  .sort-select,
  .page-link {
    font-family: var(--font-label);
    font-size: 10px;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
  }
  .products-sort label > span:first-child,
  .products-count {
    color: var(--light-sub);
  }
  .filter-btn,
  .page-link,
  .sort-select {
    border: 1px solid var(--light-border);
    background: white;
    color: var(--light-sub);
    border-radius: var(--radius-sharp);
    transition: border-color 0.2s, color 0.2s, background 0.2s;
  }
  .filter-btn {
    padding: var(--space-3) 1.25rem;
  }
  .filter-btn:hover,
  .page-link:hover {
    border-color: var(--light-fg);
    color: var(--light-fg);
  }
  .filter-btn.is-active,
  .page-link.is-active {
    background: var(--light-fg);
    color: var(--light-bg);
    border-color: var(--light-fg);
  }
  .select-wrap {
    position: relative;
    display: inline-flex;
    align-items: center;
  }
  .sort-select {
    height: 40px;
    appearance: none;
    outline: none;
    padding: 0 36px 0 14px;
  }
  .select-icon {
    pointer-events: none;
    position: absolute;
    right: 12px;
    width: 12px;
    height: 12px;
    color: var(--light-sub);
  }
  .products-count {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }
  .products-grid {
    background: transparent;
  }
  .products-grid-inner {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-5);
  }
  .products-section--complete :global(.prod-card-img) {
    border-radius: var(--radius-sharp);
  }
  .products-section--complete :global(.prod-card-img .product-img) {
    aspect-ratio: 1 / 1;
  }
  .products-section--featured :global(.prod-card-img .product-img) {
    aspect-ratio: 1 / 1;
  }
  .product-cell {
    min-width: 0;
    height: 100%;
  }
  .prod-scroll-outer {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    cursor: grab;
    scrollbar-width: thin;
    scrollbar-color: var(--light-border) transparent;
    mask-image: linear-gradient(to right, black 85%, transparent 100%);
    -webkit-mask-image: linear-gradient(to right, black 85%, transparent 100%);
  }
  .prod-scroll-outer:active { cursor: grabbing; }
  .prod-scroll-grid {
    display: flex;
    gap: 1px;
    background: var(--light-border);
    width: max-content;
    min-width: 100%;
  }
  .products-section--featured .prod-scroll-grid {
    background: transparent;
    gap: 1px;
  }
  .prod-scroll-grid .product-cell {
    width: clamp(240px, 28vw, 300px);
    flex-shrink: 0;
  }
  .products-section--featured .product-cell {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-sharp);
    overflow: hidden;
  }
  .products-empty {
    margin-top: 2rem;
    text-align: center;
    font-size: 14px;
    font-weight: 300;
    color: var(--light-sub);
  }
  .products-pagination {
    margin-top: 3rem;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 4px;
  }
