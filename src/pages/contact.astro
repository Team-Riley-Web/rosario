---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import heroImage from '../assets/images/model8.png';

const contactOptions = [
  ['Have a Question About a Piece?', "Send me a message and I'll help you figure out if it's the right fit.", 'Contact Form'],
  ['Shopping for a Gift?', "Let's get on a quick call. I'll ask about the person you're shopping for and help you choose with confidence.", 'Schedule a Call'],
  ['Sourcing Beads for Your Own Work?', 'I answer sizing, quantity, and material questions directly - no faceless storefront.', 'Message Me'],
];
---

<Layout
  title="Contact Rosario Leonardi Murano Glass"
  description="Ask a question before buying one-of-a-kind Murano glass jewelry, gifts, or maker beads."
>
  <Nav />
  <main>
    <section id="hero" class="relative overflow-hidden bg-ink px-6 pb-24 pt-40 text-white sm:px-10">
      <img
        src={heroImage.src}
        alt=""
        class="absolute inset-0 h-full w-full object-cover"
        aria-hidden="true"
      />
      <div class="absolute inset-0 bg-ink/70" aria-hidden="true"></div>
      <div class="relative mx-auto max-w-[1040px]">
        <div class="mb-8 flex items-center gap-4">
          <div class="h-px w-6 bg-gold"></div>
          <span class="font-mono text-[10px] uppercase tracking-[0.2em] text-gold">Contact</span>
        </div>
        <h1 class="mb-7 font-display text-[48px] font-light leading-none tracking-normal md:text-[76px]">
          Ask Me Anything Before You Buy.
        </h1>
        <p class="max-w-[720px] font-sans text-[16px] font-light leading-[1.85] text-white/68">
          I'm a phone call or message away - not a chatbot script. Trust is earned one honest conversation at a time.
        </p>
      </div>
    </section>

    <section class="bg-white px-6 py-20 sm:px-10">
      <div class="mx-auto grid max-w-[1180px] gap-px border border-rule bg-rule lg:grid-cols-3">
        {contactOptions.map(([title, body, cta]) => (
          <article class="flex min-h-[260px] flex-col bg-white p-8">
            <h2 class="mb-4 font-display text-[30px] font-normal leading-tight text-ink">{title}</h2>
            <p class="mb-8 font-sans text-[14px] font-light leading-[1.85] text-ink-soft">{body}</p>
            <a href="#contact-form" class="mt-auto font-mono text-[10px] uppercase tracking-[0.18em] text-gold">{cta}</a>
          </article>
        ))}
      </div>
    </section>

    <section id="contact-form" class="bg-white px-6 py-24 sm:px-10">
      <div class="mx-auto grid max-w-[1120px] gap-12 lg:grid-cols-[0.8fr_1.2fr]">
        <aside>
          <h2 class="mb-5 font-display text-[42px] font-light leading-tight text-ink">Send Me a Message</h2>
          <p class="font-sans text-[14px] font-light leading-[1.8] text-ink-soft">
            I personally read and respond to every message - usually within 24 hours.
          </p>
        </aside>

        <form
          name="contact"
          method="POST"
          data-netlify="true"
          netlify-honeypot="bot-field"
          class="grid gap-5 border border-rule bg-white p-6 sm:p-10"
        >
          <input type="hidden" name="form-name" value="contact" />
          <p class="hidden"><label>Do not fill this out: <input name="bot-field" /></label></p>

          <label class="grid gap-2">
            <span class="font-mono text-[10px] uppercase tracking-[0.18em] text-ink-soft">Name</span>
            <input name="name" required class="border border-rule px-4 py-3 font-sans text-sm outline-none focus:border-gold" />
          </label>
          <label class="grid gap-2">
            <span class="font-mono text-[10px] uppercase tracking-[0.18em] text-ink-soft">Email</span>
            <input type="email" name="email" required class="border border-rule px-4 py-3 font-sans text-sm outline-none focus:border-gold" />
          </label>
          <label class="grid gap-2">
            <span class="font-mono text-[10px] uppercase tracking-[0.18em] text-ink-soft">What can I help you with?</span>
            <select name="topic" required class="border border-rule px-4 py-3 font-sans text-sm outline-none focus:border-gold">
              <option value="">Choose one</option>
              <option>Choosing a piece</option>
              <option>Gift guidance</option>
              <option>Bead sourcing for makers</option>
              <option>Order question</option>
              <option>Something else</option>
            </select>
          </label>
          <label class="grid gap-2">
            <span class="font-mono text-[10px] uppercase tracking-[0.18em] text-ink-soft">Message</span>
            <textarea name="message" rows="6" required class="border border-rule px-4 py-3 font-sans text-sm outline-none focus:border-gold"></textarea>
          </label>
          <button class="justify-self-start bg-ink px-7 py-3 font-mono text-[10px] uppercase tracking-[0.18em] text-white transition-colors hover:bg-gold-deep">
            Send Message
          </button>
        </form>
      </div>
    </section>

    <section class="bg-white px-6 py-20 sm:px-10">
      <div class="mx-auto grid max-w-[960px] gap-8 md:grid-cols-[0.8fr_1.2fr] md:items-center">
        <h2 class="font-display text-[42px] font-light leading-none text-ink">Find the Shop</h2>
        <div class="flex flex-wrap gap-3">
          <a href="https://www.etsy.com/shop/LakeviewPearls" target="_blank" rel="noopener" class="border border-rule bg-white px-6 py-3 font-mono text-[10px] uppercase tracking-[0.18em] text-ink transition-colors hover:border-gold hover:text-gold-deep">Etsy Shop: LakeviewPearls</a>
          <a href="/faq" class="border border-rule bg-white px-6 py-3 font-mono text-[10px] uppercase tracking-[0.18em] text-ink transition-colors hover:border-gold hover:text-gold-deep">Read FAQ</a>
        </div>
      </div>
    </section>

    <section class="bg-ink px-6 py-20 text-white sm:px-10">
      <div class="mx-auto max-w-[960px] text-center">
        <h2 class="mb-4 font-display text-[42px] font-light leading-none md:text-[62px]">Be Bold. Reach Out.</h2>
        <p class="font-sans text-[15px] font-light leading-[1.8] text-white/68">
          Whatever brought you here - a question, a gift, or a search for something real - I'm glad you did.
        </p>
      </div>
    </section>
  </main>
</Layout>
