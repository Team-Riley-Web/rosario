---
import { Image } from 'astro:assets';
import alainaImg from '../assets/images/imgi_27_alaina3.jpg';
import kidImg from '../assets/images/kid.jpg';

const testimonials = [
  {
    quote: "I haven't worn foundation to work in three months. I didn't even notice when it stopped feeling necessary. That's when I knew something had actually changed.",
    name: "Sandra M.",
    detail: "Executive · Age 52",
  },
  {
    quote: "I've tried La Mer, SkinCeuticals, all the clean brands. This is the first time I've seen results I can photograph. My pigmentation is actually fading.",
    name: "Karen T.",
    detail: "Teacher & Mother · Age 48",
  },
  {
    quote: "As a woman of color I've been burned by products not made for my skin. CFC is the first brand where I felt like they were thinking about me when they formulated it.",
    name: "Tasha R.",
    detail: "Attorney · Age 41",
  },
  {
    quote: "My med spa NP told me I needed better at-home care. CFC is what she recommended. Now I'm extending every treatment result — effortlessly.",
    name: "Brenda L.",
    detail: "Entrepreneur · Age 55",
  },
];
---

<section class="bg-ink py-[140px]" id="testimonials">
  <div class="max-w-[1440px] mx-auto px-10">

    <!-- Header: 2-column -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 mb-16 items-end">
      <div class="reveal-left">
        <div class="flex items-center gap-4 mb-7">
          <div class="h-px w-6 bg-[rgba(255,255,255,0.08)]"></div>
          <span class="font-mono text-[10px] tracking-[0.2em] uppercase text-gold">Real Women. Real Skin.</span>
        </div>
        <h2 class="font-display font-light text-white leading-none tracking-[-0.02em]" style="font-size: clamp(42px, 4.5vw, 68px);">
          The results speak for themselves.
        </h2>
      </div>
      <div class="reveal-right">
        <p class="font-sans font-light text-[14px] leading-[1.7] text-[rgba(255,255,255,0.5)]">
          Women across the country are experiencing real, photographable results from the CFC protocol. Three steps. Five minutes. A lifetime of confidence.
        </p>
      </div>
    </div>

    <!-- Grid: 3 cols, 6 cells -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-px">

      {[
        { testimonial: testimonials[0], delay: 0 },
        { isImage: true, src: alainaImg, alt: 'Woman applying CFC skincare', delay: 80 },
        { testimonial: testimonials[1], delay: 160 },
        { isImage: true, src: kidImg, alt: 'Young woman with radiant skin', delay: 240 },
        { testimonial: testimonials[2], delay: 320 },
        { testimonial: testimonials[3], delay: 400 },
      ].map((cell) => cell.isImage ? (
        <div class="reveal min-h-[340px] overflow-hidden" style={`transition-delay: ${cell.delay}ms;`}>
          <Image
            src={cell.src}
            alt={cell.alt}
            class="w-full h-full min-h-[340px] object-cover object-top"
            widths={[400, 700]}
            sizes="(max-width: 768px) 100vw, 33vw"
          />
        </div>
      ) : (
        <div
          class="reveal flex flex-col px-10 py-12"
          style={`background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.05); transition-delay: ${cell.delay}ms;`}
          onmouseover="this.style.background='rgba(255,255,255,0.055)'"
          onmouseout="this.style.background='rgba(255,255,255,0.03)'"
        >
          <div class="text-gold text-[12px] tracking-[4px] mb-4">★★★★★</div>
          <p class="font-display italic font-light flex-1 mb-6 text-[19px] leading-[1.5]" style="color: rgba(255,255,255,0.8);">
            "{cell.testimonial.quote}"
          </p>
          <div class="pt-5" style="border-top: 1px solid rgba(255,255,255,0.08);">
            <p class="font-display text-[16px] font-normal text-white">{cell.testimonial.name}</p>
            <p class="font-mono text-[9px] tracking-[0.15em] uppercase mt-1" style="color: rgba(255,255,255,0.35);">{cell.testimonial.detail}</p>
          </div>
        </div>
      ))}

    </div>
  </div>
</section>
