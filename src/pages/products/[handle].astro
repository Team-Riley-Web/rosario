---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import ProductCard from '../../components/ProductCard.astro';
import { CalendarSync, ChevronLeft, ChevronRight, Maximize2, ShoppingBag, X } from '@lucide/astro';
import { getAllProducts, getProductByHandle, getFeaturedProducts, formatPrice } from '../../lib/shopify';
import type { ShopifyProductDetail } from '../../lib/shopify';

export async function getStaticPaths() {
  const products = await getAllProducts();
  return products.map((p) => ({ params: { handle: p.handle } }));
}

const { handle } = Astro.params;
const product = await getProductByHandle(handle!) as ShopifyProductDetail | null;

if (!product) return Astro.redirect('/shop');

const images = product.images.edges.map(e => e.node);
const variants = product.variants.edges.map(e => e.node);
const relatedProducts = product.relatedProducts?.length ? product.relatedProducts : await getFeaturedProducts();
const hasVariantChoice = variants.length > 1 && variants[0]?.title !== 'Default Title';
const variantOptionLabel = product.options?.find((option) => option.name && option.name !== 'Title')?.name ?? 'Select Option';
const firstAvailableId = variants.find(v => v.availableForSale)?.id ?? variants[0]?.id ?? '';

const minPrice = formatPrice(product.priceRange.minVariantPrice.amount);
const maxPrice = formatPrice(product.priceRange.maxVariantPrice.amount);
const priceDisplay = minPrice !== maxPrice ? `${minPrice} – ${maxPrice}` : minPrice;
const firstAvailableVariant = variants.find(v => v.id === firstAvailableId) ?? variants[0];
const firstAvailablePrice = firstAvailableVariant?.price.amount ? formatPrice(firstAvailableVariant.price.amount) : priceDisplay;
const hasSellingPlans = variants.some((variant) => (variant.sellingPlanAllocations?.edges.length ?? 0) > 0);

function getStep(p: ShopifyProductDetail): { label: string; num: string } | null {
  const label = p.tags[0] || p.collections.edges[0]?.node.title;
  return label ? { label, num: '01' } : null;
}
const step = getStep(product);
const productSellingPlans = product.sellingPlanGroups?.edges.flatMap(({ node: group }) => (
  group.sellingPlans.edges.map(({ node: sellingPlan }) => {
    const deliveryOption = sellingPlan.options.find(option => /deliver|frequency|every/i.test(option.name))?.value
      ?? sellingPlan.options[0]?.value
      ?? group.options[0]?.values[0]
      ?? '';

    return {
      id: sellingPlan.id,
      groupName: group.name,
      originalName: sellingPlan.name,
      deliveryOption,
      description: sellingPlan.description,
    };
  })
)) ?? [];
const fallbackSellingPlans = variants.flatMap((v) => (v.sellingPlanAllocations?.edges ?? []).map(({ node }) => {
  const deliveryOption = node.sellingPlan.options.find(option => /deliver|frequency|every/i.test(option.name))?.value
    ?? node.sellingPlan.options[0]?.value
    ?? '';

  return {
    id: node.sellingPlan.id,
    groupName: node.sellingPlan.name,
    originalName: node.sellingPlan.name,
    deliveryOption,
    description: node.sellingPlan.description,
  };
}));
const sellingPlans = Array.from(
  new Map((productSellingPlans.length > 0 ? productSellingPlans : fallbackSellingPlans).map((plan) => [plan.id, plan])).values()
).sort((a, b) => {
  const score = (plan: { groupName: string; originalName: string }) => {
    const text = `${plan.groupName} ${plan.originalName}`.toLowerCase();
    return text.includes('subscribe') || text.includes('subscription') ? 0 : 1;
  };
  return score(a) - score(b);
});
const displayPlanName = (plan: { groupName: string; originalName: string }, discount: number) => {
  const text = `${plan.groupName} ${plan.originalName}`.toLowerCase();
  if (plan.originalName) return plan.originalName;
  if (text.includes('subscribe') || text.includes('subscription') || discount > 0) return 'Subscribe and save';
  return 'Subscription';
};
const displayDiscount = (plan: { groupName: string; originalName: string }, discount: number) => {
  if (discount > 0) return `Save ${discount}%`;
  return 'Subscribe';
};
const variantsJson = JSON.stringify(variants.map(v => ({
  id: v.id,
  title: v.title,
  available: v.availableForSale,
  price: formatPrice(v.price.amount),
  sellingPlans: sellingPlans.map((plan) => {
    const allocation = (v.sellingPlanAllocations?.edges ?? []).find(({ node }) => node.sellingPlan.id === plan.id)?.node;
    const priceAdjustment = allocation?.priceAdjustments[0];
    const planPrice = Number(priceAdjustment?.price.amount ?? 0);
    const compareAtPrice = Number(priceAdjustment?.compareAtPrice?.amount ?? v.price.amount);
    const discount = compareAtPrice > planPrice && planPrice > 0
      ? Math.round(((compareAtPrice - planPrice) / compareAtPrice) * 100)
      : 0;

    return {
      id: plan.id,
      name: displayPlanName(plan, discount),
      originalName: plan.originalName,
      description: plan.description,
      deliveryOption: plan.deliveryOption,
      price: priceAdjustment?.price.amount ? formatPrice(priceAdjustment.price.amount, priceAdjustment.price.currencyCode) : '',
      compareAtPrice: priceAdjustment?.compareAtPrice?.amount ? formatPrice(priceAdjustment.compareAtPrice.amount, priceAdjustment.compareAtPrice.currencyCode) : '',
      discountLabel: displayDiscount(plan, discount),
    };
  }),
})));
---

<Layout
  title={`${product.title} — Rosario Leonardi Murano Glass`}
  description={product.description?.slice(0, 155) || 'One-of-a-kind Murano glass product details with verified sourcing.'}
  image={images[0]?.url}
>
  <Nav position="sticky" />
  <main class="bg-white">

    <!-- Breadcrumb bar -->
    <div class="bg-gradient-to-r from-ink to-black">
      <div class="max-w-[1440px] mx-auto px-10 py-3 flex items-center gap-2.5">
        <a
          href="/shop"
          class="inline-flex items-center gap-2 font-mono text-[9px] tracking-[0.18em] uppercase text-gold-light hover:text-gold transition-colors duration-200"
        >
          <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
          </svg>
          All Pieces
        </a>
        <span class="font-mono text-[9px] text-white/20">/</span>
        <span class="font-mono text-[9px] tracking-[0.12em] uppercase text-white truncate max-w-[240px]">{product.title}</span>
      </div>
    </div>

    <!-- Product section -->
    <section class="py-16 lg:py-24">
      <div class="max-w-5xl mx-auto px-10">
        <div class="grid grid-cols-1 lg:grid-cols-[1.1fr_1fr] gap-12 xl:gap-20 items-start">

          <!-- Left: image gallery -->
          <div
            x-data={`{
              active: 0,
              modalOpen: false,
              imageCount: ${images.length},
              openModal(index) {
                this.active = index;
                this.modalOpen = true;
                document.documentElement.classList.add('overflow-hidden');
              },
              closeModal() {
                this.modalOpen = false;
                document.documentElement.classList.remove('overflow-hidden');
              },
              nextImage() {
                if (!this.imageCount) return;
                this.active = (this.active + 1) % this.imageCount;
              },
              prevImage() {
                if (!this.imageCount) return;
                this.active = (this.active - 1 + this.imageCount) % this.imageCount;
              }
            }`}
            @keydown.escape.window="modalOpen && closeModal()"
            @keydown.arrow-right.window="modalOpen && nextImage()"
            @keydown.arrow-left.window="modalOpen && prevImage()"
            class="reveal-left lg:sticky lg:top-[100px]"
          >

            <!-- Main image -->
            <div class="relative overflow-hidden bg-parchment aspect-[3/4]">
              {images.length > 0 ? (
                <button
                  type="button"
                  class="absolute inset-0 block h-full w-full cursor-zoom-in text-left"
                  @click="openModal(active)"
                  aria-label="Open larger product image gallery"
                >
                  {images.map((img, i) => (
                    <img
                      src={img.url}
                      alt={img.altText ?? product.title}
                      class="absolute inset-0 w-full h-full object-cover transition-opacity duration-400"
                      x-show={`active === ${i}`}
                      loading={i === 0 ? 'eager' : 'lazy'}
                      width="900"
                      height="1200"
                    />
                  ))}
                  <span class="absolute bottom-4 right-4 inline-flex h-10 w-10 items-center justify-center bg-white/90 text-ink shadow-sm transition-colors duration-200 hover:bg-white">
                    <Maximize2 class="h-4 w-4" stroke-width={1.7} />
                  </span>
                </button>
              ) : (
                <div class="w-full h-full flex items-center justify-center">
                  <span class="font-display text-5xl text-rule">Product</span>
                </div>
              )}

              {step && (
                <span class="absolute top-4 left-4 bg-white text-gold-deep font-mono text-[9px] tracking-[0.12em] uppercase px-2 py-1">
                  {step.label}
                </span>
              )}
              {!product.availableForSale && (
                <span class="absolute top-4 right-4 bg-ink text-white font-mono text-[9px] tracking-[0.12em] uppercase px-2 py-1">
                  Sold Out
                </span>
              )}
            </div>

            <!-- Thumbnails -->
            {images.length > 1 && (
              <div class="flex gap-2 mt-3 flex-wrap">
                {images.map((img, i) => (
                  <button
                    @click={`active = ${i}`}
                    :class={`active === ${i} ? 'border-gold' : 'border-rule hover:border-ink/40'`}
                    class="w-[72px] h-[96px] shrink-0 overflow-hidden border-2 transition-colors duration-200"
                    aria-label={`Image ${i + 1}`}
                  >
                    <img
                      src={img.url}
                      alt={img.altText ?? product.title}
                      class="w-full h-full object-cover"
                      loading="lazy"
                    />
                  </button>
                ))}
              </div>
            )}

            {images.length > 0 && (
              <div
                x-show="modalOpen"
                x-cloak
                x-transition.opacity.duration.200ms
                class="fixed inset-0 z-[120] bg-ink/95 px-4 py-5 text-white sm:px-8 sm:py-8"
                role="dialog"
                aria-modal="true"
                aria-label="Product image gallery"
              >
                <button
                  type="button"
                  class="absolute right-4 top-4 z-10 inline-flex h-11 w-11 items-center justify-center border border-white/20 bg-white/10 text-white transition-colors duration-200 hover:bg-white hover:text-ink sm:right-8 sm:top-8"
                  @click="closeModal()"
                  aria-label="Close image gallery"
                >
                  <X class="h-5 w-5" stroke-width={1.7} />
                </button>

                {images.length > 1 && (
                  <>
                    <button
                      type="button"
                      class="absolute left-4 top-1/2 z-10 inline-flex h-11 w-11 -translate-y-1/2 items-center justify-center border border-white/20 bg-white/10 text-white transition-colors duration-200 hover:bg-white hover:text-ink sm:left-8"
                      @click="prevImage()"
                      aria-label="Previous image"
                    >
                      <ChevronLeft class="h-6 w-6" stroke-width={1.6} />
                    </button>
                    <button
                      type="button"
                      class="absolute right-4 top-1/2 z-10 inline-flex h-11 w-11 -translate-y-1/2 items-center justify-center border border-white/20 bg-white/10 text-white transition-colors duration-200 hover:bg-white hover:text-ink sm:right-8"
                      @click="nextImage()"
                      aria-label="Next image"
                    >
                      <ChevronRight class="h-6 w-6" stroke-width={1.6} />
                    </button>
                  </>
                )}

                <button
                  type="button"
                  class="absolute inset-0 h-full w-full cursor-zoom-out"
                  @click="closeModal()"
                  aria-label="Close image gallery backdrop"
                ></button>

                <div class="relative z-[1] mx-auto grid h-full max-w-6xl grid-rows-[1fr_auto] gap-4">
                  <div class="flex min-h-0 items-center justify-center px-10 sm:px-14">
                    {images.map((img, i) => (
                      <img
                        src={img.url}
                        alt={img.altText ?? product.title}
                        class="max-h-full max-w-full object-contain"
                        x-show={`active === ${i}`}
                        loading="lazy"
                      />
                    ))}
                  </div>

                  {images.length > 1 && (
                    <div class="mx-auto flex max-w-full gap-2 overflow-x-auto pb-1">
                      {images.map((img, i) => (
                        <button
                          type="button"
                          @click={`active = ${i}`}
                          :class={`active === ${i} ? 'border-gold' : 'border-white/25 hover:border-white/70'`}
                          class="h-16 w-12 shrink-0 overflow-hidden border-2 bg-white/10 transition-colors duration-200 sm:h-20 sm:w-16"
                          aria-label={`View image ${i + 1}`}
                        >
                          <img
                            src={img.url}
                            alt={img.altText ?? product.title}
                            class="h-full w-full object-cover"
                            loading="lazy"
                          />
                        </button>
                      ))}
                    </div>
                  )}
                </div>
              </div>
            )}
          </div>

          <!-- Right: product info -->
          <div
            class="reveal-right"
            x-data={`{
              adding: false,
              added: false,
              selectedId: ${JSON.stringify(firstAvailableId)},
              purchaseOption: 'one-time',
              selectedSellingPlanId: '',
              variants: ${variantsJson},
              currentVariant() {
                return this.variants.find((variant) => variant.id === this.selectedId) || this.variants[0] || { price: ${JSON.stringify(firstAvailablePrice)}, sellingPlans: [] };
              },
              currentPrice() {
                return this.currentVariant().price || ${JSON.stringify(firstAvailablePrice)};
              },
              currentSellingPlans() {
                return this.currentVariant().sellingPlans || [];
              },
              selectVariant(id) {
                this.selectedId = id;
                if (this.purchaseOption === 'subscription') {
                  const plan = this.currentSellingPlans()[0];
                  this.selectedSellingPlanId = plan?.id || '';
                  if (!this.selectedSellingPlanId) this.purchaseOption = 'one-time';
                }
              },
              selectOneTime() {
                this.purchaseOption = 'one-time';
                this.selectedSellingPlanId = '';
              },
              selectSubscription(planId) {
                this.purchaseOption = 'subscription';
                this.selectedSellingPlanId = planId;
              },
              async buyNow() {
                if (this.adding || !this.selectedId) return;
                this.adding = true;
                await $store.cart.addItem(this.selectedId, 1, this.selectedSellingPlanId || undefined);
                this.adding = false;
                if ($store.cart.checkoutUrl) window.location.href = $store.cart.checkoutUrl;
              }
            }`}
          >

            <!-- Step / category -->
            {step && (
              <div class="flex items-center gap-3 mb-5">
                <div class="h-px bg-gold w-6"></div>
                <span class="font-mono text-[9px] tracking-[0.2em] uppercase text-gold">
                  {step.label}
                </span>
              </div>
            )}

            <h1
              class="font-display font-light text-ink leading-[1.05] tracking-[-0.01em] mb-4"
              style="font-size: clamp(28px, 3.2vw, 44px);"
            >
              {product.title}
            </h1>

            <p class="font-display text-[26px] font-normal text-ink mb-7" x-text="currentPrice()">{firstAvailablePrice}</p>

            {product.description && (
              <p class="font-sans font-light text-[14px] leading-[1.8] text-ink mb-8 max-w-[460px]">
                {product.description.slice(0, 220)}{product.description.length > 220 ? '…' : ''}
              </p>
            )}

            <!-- Variant + cart block -->
            <div>
              {hasVariantChoice && (
                <div class="mb-6">
                  <p class="font-mono text-[9px] tracking-[0.18em] uppercase text-ink-soft mb-3">{variantOptionLabel}</p>
                  <div class="flex flex-wrap gap-2">
                    {variants.map((v) => (
                      <button
                        type="button"
                        @click={`selectVariant(${JSON.stringify(v.id)})`}
                        :class={`selectedId === ${JSON.stringify(v.id)} ? 'bg-ink text-white border-ink' : 'bg-white text-ink border-rule hover:border-ink'`}
                        class="font-mono text-[10px] tracking-[0.1em] uppercase border px-4 py-2.5 transition-all duration-200"
                        disabled={!v.availableForSale || undefined}
                        style={!v.availableForSale ? 'opacity: 0.4; cursor: not-allowed;' : undefined}
                      >
                        {v.title}
                      </button>
                    ))}
                  </div>
                </div>
              )}

              {hasSellingPlans && (
                <div class="mb-6">
                  <p class="font-mono text-[9px] tracking-[0.18em] uppercase text-ink-soft mb-3">Purchase Options</p>
                  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <button
                      type="button"
                      @click="selectOneTime()"
                      :class="purchaseOption === 'one-time' ? 'border-gold-deep text-gold-deep' : 'border-rule text-ink-soft hover:border-gold'"
                      class="relative min-h-[76px] w-full border bg-white px-4 py-3 text-left transition-all duration-200"
                    >
                      <span class="flex items-center gap-3">
                        <ShoppingBag class="h-7 w-7 shrink-0" stroke-width={1.7} />
                        <span class="font-display text-[17px] leading-tight">One-time Purchase</span>
                      </span>
                    </button>

                    {sellingPlans.map((plan) => {
                      const label = displayPlanName(plan, 0);
                      const discountLabel = displayDiscount(plan, 0);
                      return (
                      <button
                        type="button"
                        @click={`selectSubscription(${JSON.stringify(plan.id)})`}
                        :class={`selectedSellingPlanId === ${JSON.stringify(plan.id)} ? 'border-gold-deep text-gold-deep' : 'border-rule text-ink-soft hover:border-gold'`}
                        class="relative min-h-[76px] w-full border bg-white px-4 py-3 text-left transition-all duration-200"
                      >
                        <span
                          class="absolute -top-3 right-3 bg-gold-deep px-2 py-1 font-mono text-[9px] leading-none tracking-[0.08em] uppercase text-white"
                        >
                          {discountLabel}
                        </span>
                        <span class="flex items-center gap-3">
                          <CalendarSync class="h-7 w-7 shrink-0" stroke-width={1.7} />
                          <span>
                            <span class="block font-display text-[17px] leading-tight">{label}</span>
                            {plan.deliveryOption && (
                              <span class="block font-sans text-[11px] font-light mt-0.5 opacity-70">{plan.deliveryOption}</span>
                            )}
                          </span>
                        </span>
                      </button>
                      );
                    })}
                  </div>
                </div>
              )}

              {product.availableForSale ? (
                <button
                  @click={`if (!adding && !added) {
                    adding = true;
                    await $store.cart.addItem(selectedId, 1, selectedSellingPlanId || undefined);
                    adding = false;
                    added = true;
                    setTimeout(() => { added = false; }, 2000);
                  }`}
                  :disabled="adding || undefined"
                  class="w-full font-mono text-[10px] tracking-[0.2em] uppercase py-4 mb-3 transition-all duration-200"
                  :class="added ? 'bg-gold-deep text-white' : 'bg-ink text-white hover:bg-gold-deep'"
                >
                  <span x-show="!adding && !added">Add to Cart</span>
                  <span x-show="adding" x-cloak>Adding…</span>
                  <span x-show="added" x-cloak>Added to Cart ✓</span>
                </button>
              ) : (
                <button
                  disabled
                  class="w-full bg-rule text-ink-soft font-mono text-[10px] tracking-[0.2em] uppercase py-4 mb-3 cursor-not-allowed"
                >
                  Sold Out
                </button>
              )}

              {hasSellingPlans && (
                <p
                  x-show="selectedSellingPlanId"
                  x-cloak
                  class="font-sans text-[11px] leading-[1.6] text-ink-soft mb-3"
                >
                  This item is a recurring or deferred purchase. By continuing, you agree to the cancellation policy and authorize charges at the prices, frequency, and dates shown until fulfilled or canceled, if permitted.
                </p>
              )}

              <button
                type="button"
                @click="buyNow()"
                :disabled="adding || undefined"
                class="block w-full text-center font-mono text-[10px] tracking-[0.2em] uppercase py-4 border border-rule text-ink-soft hover:border-ink hover:text-ink transition-colors duration-200"
              >
                Buy Now
              </button>
            </div>

            <!-- Trust indicators -->
            <div class="border-t border-rule mt-8 pt-7 space-y-3.5">
              {[
                ['Lifetime Warranty', 'Backed against product defects'],
                ['One of a Kind', "Won't be restocked once it sells"],
                ['Gift-Boxed', 'Arrives beautifully boxed with a gold label'],
              ].map(([label, desc]) => (
                <div class="flex items-start gap-3">
                  <div class="shrink-0 flex items-center justify-center mt-[3px] w-[14px] h-[14px] border border-gold rounded-full">
                    <svg class="text-gold" width="7" height="5" viewBox="0 0 10 8" fill="none" stroke="currentColor" stroke-width="1.5">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M1 4l2.5 2.5L9 1"/>
                    </svg>
                  </div>
                  <span class="font-sans font-light text-[13px] text-ink-soft">
                    <strong class="font-medium text-ink">{label}</strong> — {desc}
                  </span>
                </div>
              ))}
            </div>

          </div>
        </div>
      </div>
    </section>

    <!-- Full description -->
    {product.descriptionHtml && (
      <section class="pb-20">
        <div class="max-w-5xl mx-auto px-10">
          <div class="grid grid-cols-1 lg:grid-cols-[200px_1fr] gap-10 xl:gap-20">

            <!-- Left: label -->
            <div class="lg:pt-6 flex flex-wrap items-center gap-4 lg:flex-col lg:items-start lg:gap-5">
              <div class="flex items-center gap-4">
                <div class="h-px bg-gold w-6 shrink-0"></div>
                <span class="font-mono text-[10px] font-semibold tracking-[0.2em] uppercase text-ink whitespace-nowrap">Product Details</span>
              </div>

              <a href="/contact" class="hidden font-mono text-[10px] uppercase tracking-[0.18em] text-gold lg:inline-flex">
                Have a question? Ask me →
              </a>
            </div>

            <!-- Right: content -->
            <div class="product-description" set:html={product.descriptionHtml} />

          </div>
        </div>
      </section>
    )}

    {relatedProducts.length > 0 && (
      <section class="bg-parchment py-20">
        <div class="max-w-5xl mx-auto px-10">
          <div class="flex items-center gap-4 mb-10">
            <div class="h-px bg-gold w-6 shrink-0"></div>
            <span class="font-mono text-[10px] tracking-[0.2em] uppercase text-gold">More One-of-a-Kind Pieces</span>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-px">
            {relatedProducts.slice(0, 4).map((relatedProduct) => (
              <ProductCard product={relatedProduct} />
            ))}
          </div>
        </div>
      </section>
    )}

  </main>
</Layout>

<style>
  .product-description :global(p) {
    font-family: var(--font-body);
    font-weight: 300;
    font-size: 14px;
    line-height: 1.85;
    color: oklch(18% 0.010 255);
    margin-bottom: 1rem;
  }
  .product-description :global(strong) {
    font-weight: 500;
    color: oklch(13% 0.010 255);
  }
  .product-description :global(h1),
  .product-description :global(h2),
  .product-description :global(h3) {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-weight: 300;
    color: oklch(13% 0.010 255);
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
  }
  .product-description :global(ul),
  .product-description :global(ol) {
    padding-left: 1.25rem;
    margin-bottom: 1rem;
    font-family: var(--font-body);
    font-weight: 300;
    font-size: 14px;
    line-height: 1.85;
    color: oklch(18% 0.010 255);
  }
  .product-description :global(li) {
    margin-bottom: 0.35rem;
  }
  /* Strip Shopify editor noise */
  .product-description :global([data-start]),
  .product-description :global([data-end]) {
    all: revert;
  }
</style>
